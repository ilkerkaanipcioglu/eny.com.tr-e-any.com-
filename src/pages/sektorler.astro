---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { 
  Clover,
  Nut,
  Sprout,
  Fish,
  Bird,
  ArrowRight
} from '@lucide/astro';

const lang = 'tr' as const;
---
<Layout title="Sektörler | eny" lang={lang}>
    <Header lang={lang} />
    <section class="pt-40 pb-24 bg-bg px-8 border-b border-border-main">
        <div class="max-w-[1440px] mx-auto">
            <h1 class="display-lg text-5xl md:text-7xl font-bold font-headline text-text tracking-tight mb-8">
                Sektörünüzün Çetin<br/>Dinamiklerini Biliyoruz.
            </h1>
            <p class="text-xl md:text-2xl text-text-70 font-light leading-relaxed max-w-3xl">
                Genel geçer yazılım çözümleri sunmuyoruz. Her sektörün kendine has regülasyonlarını ve nakit döngülerini merkeze alan uyarlanmış mimariler inşa ediyoruz.
            </p>
        </div>
    </section>

    <!-- Sectors Detailed List -->
    <section class="py-0">
        <!-- 1: Perakende -->
        <article class="py-24 px-8 border-b border-border-main bg-bg2 hover:bg-bg transition-all duration-700">
            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                <div class="lg:col-span-4">
                    <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <Clover size={32} class="lucide-icon icon-bounce-hover" />
                    </div>
                    <h2 class="text-4xl font-headline font-bold text-text mb-4">Perakende ve<br/>Hızlı Tüketim</h2>
                </div>
                <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div>
                        <h4 class="text-sm tracking-widest text-text-70 uppercase font-bold mb-4">Kritik Problem</h4>
                        <p class="text-text leading-relaxed">Binlerce mağazadan, onlarca farklı POS cihazından aynı anda akan devasa işlemin mutabakatı, ciro primlerinin hesaplanması ve nakit lojistiğinin takibi korkunç bir operasyonel yüktür.</p>
                    </div>
                    <div>
                        <h4 class="text-sm tracking-widest text-lime uppercase font-bold mb-4">eny Çözümü</h4>
                        <p class="text-text leading-relaxed font-light">POS Veri Ambarı ve Nakit Yönetim Entegrasyonuyla tüm nakit akışını anlık izleyen, mağaza bazlı kârlılık çıkaran otomatik yapılar kuruyoruz.</p>
                    </div>
                </div>
            </div>
        </article>

        <!-- 2: Uretim -->
        <article class="py-24 px-8 border-b border-border-main bg-bg2 hover:bg-bg transition-all duration-700">
            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                <div class="lg:col-span-4">
                    <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <Nut size={32} class="lucide-icon icon-bounce-hover" />
                    </div>
                    <h2 class="text-4xl font-headline font-bold text-text mb-4">Üretim ve<br/>Otomotiv Sanayi</h2>
                </div>
                <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div>
                        <h4 class="text-sm tracking-widest text-text-70 uppercase font-bold mb-4">Kritik Problem</h4>
                        <p class="text-text leading-relaxed">Hammadde fiyat dalgalanmaları, karmaşık tedarik zinciri finansmanı ve uzun vadeli yatırım kararlarının ürün bazlı gerçek maliyet analizini zorlaştırması.</p>
                    </div>
                    <div>
                        <h4 class="text-sm tracking-widest text-primary uppercase font-bold mb-4">eny Çözümü</h4>
                        <p class="text-text leading-relaxed font-light">Hazine ve Risk Yönetimi üzerinden emtia (commodity) risklerini heç eden ve ileri seviye maliyet kontroling modülleriyle gerçek zamanlı kesin maliyet raporlaması sunan entegre fabrikalar inşa ediyoruz.</p>
                    </div>
                </div>
            </div>
        </article>

        <!-- 3: Insaat Gayrimenkul -->
        <article class="py-24 px-8 border-b border-border-main bg-bg2 hover:bg-bg transition-all duration-700">
            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                <div class="lg:col-span-4">
                    <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <Sprout size={32} class="lucide-icon icon-bounce-hover" />
                    </div>
                    <h2 class="text-4xl font-headline font-bold text-text mb-4">İnşaat ve<br/>Gayrimenkul (GYO)</h2>
                </div>
                <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div>
                        <h4 class="text-sm tracking-widest text-text-70 uppercase font-bold mb-4">Kritik Problem</h4>
                        <p class="text-text leading-relaxed">Çok sayıda alışveriş merkezi veya ofis projesinde; yüzlerce kiracının sözleşmelerini, ciroya endeksli kira artışlarını ve ortak alan gider masraflarını hatasız yönetememek.</p>
                    </div>
                    <div>
                        <h4 class="text-sm tracking-widest text-lime uppercase font-bold mb-4">eny Çözümü</h4>
                        <p class="text-text leading-relaxed font-light">Merkezi gayrimenkul yönetim sistemleri uygulayarak IFRS 16 hesaplamalarını, m² bazlı faturalandırmayı ve tesis bakım uyarılarını tamamen otomatize ediyoruz.</p>
                    </div>
                </div>
            </div>
        </article>

        <!-- 4: Bankacilik Finans -->
        <article class="py-24 px-8 border-b border-border-main bg-bg2 hover:bg-bg transition-all duration-700">
            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                <div class="lg:col-span-4">
                    <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <Fish size={32} class="lucide-icon icon-bounce-hover" />
                    </div>
                    <h2 class="text-4xl font-headline font-bold text-text mb-4">Finansal Hizmetler<br/>ve Holdingler</h2>
                </div>
                <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div>
                        <h4 class="text-sm tracking-widest text-text-70 uppercase font-bold mb-4">Kritik Problem</h4>
                        <p class="text-text leading-relaxed">Holding bünyesindeki farklı alt şirketlerin nakdini tek bir havuzda yönetememek, grup içi fon transferlerinde zaman ve komisyon kaybı yaşamak.</p>
                    </div>
                    <div>
                        <h4 class="text-sm tracking-widest text-primary uppercase font-bold mb-4">eny Çözümü</h4>
                        <p class="text-text leading-relaxed font-light">Gelişmiş Kurumiçi Bankacılık ve Nakit Havuzlama (Cash Pooling) stratejileriyle içeride sanal bir banka kurarak holding verimliliğini %40 artırıyoruz.</p>
                    </div>
                </div>
            </div>
        </article>

        <!-- 5: Lojistik -->
        <article class="py-24 px-8 border-b border-border-main bg-bg2 hover:bg-bg transition-all duration-700">
            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                <div class="lg:col-span-4">
                    <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <Bird size={32} class="lucide-icon icon-bounce-hover" />
                    </div>
                    <h2 class="text-4xl font-headline font-bold text-text mb-4">Lojistik ve<br/>Tedarik Zinciri</h2>
                </div>
                <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div>
                        <h4 class="text-sm tracking-widest text-text-70 uppercase font-bold mb-4">Kritik Problem</h4>
                        <p class="text-text leading-relaxed">Karmaşık filo masrafları, yakıt maliyetleri ve gümrük faturalarının işlenmesinde yaşanan gecikmelerin şirket bütçesinde kör noktalar yaratması.</p>
                    </div>
                    <div>
                        <h4 class="text-sm tracking-widest text-lime uppercase font-bold mb-4">eny Çözümü</h4>
                        <p class="text-text leading-relaxed font-light">Dijital arşiv ve fatura otomasyon sistemleriyle nakliye ve tedarikçi faturalarını OCR üzerinden saniyeler içinde işleyerek anlık gider görünürlüğü sağlıyoruz.</p>
                    </div>
                </div>
            </div>
        </article>
    </section>
    
    <!-- Final CTA -->
    <section class="py-20 bg-bg">
        <div class="max-w-4xl mx-auto px-8 text-center text-text">
            <h2 class="text-3xl font-bold font-headline mb-6">Siz de Kendi Sektörünüzde<br/>Öncü Olmak İster misiniz?</h2>
            <a href="/iletisim" class="inline-flex items-center gap-2 bg-lime text-black px-8 py-3 rounded-lg font-bold hover:-translate-y-1 hover:shadow-xl transition-all">
                Bizimle İletişime Geçin <ArrowRight size={16} />
            </a>
        </div>
    </section>
    <Footer lang={lang} />
</Layout>
