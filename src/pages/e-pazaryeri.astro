---
import Layout from '../layouts/Layout.astro';
import { Rabbit } from '@lucide/astro';
---
<Layout title="Yönlendiriliyorsunuz..." lang="tr">
    <div class="min-h-screen flex items-center justify-center bg-bg">
        <div class="text-center">
            <Rabbit size={64} class="text-lime mb-6 animate-pulse mx-auto" />
            <h1 class="text-2xl font-bold text-text mb-4">Yeni Çözüm Sayfamıza Yönlendiriliyorsunuz</h1>
            <p class="text-text-70">e-Pazaryeri ve e-Ticaret çözümlerimiz artık tek bir çatı altında birleşti.</p>
        </div>
    </div>
    <script is:inline>
        window.location.href = '/e-ticaret';
    </script>
</Layout>
