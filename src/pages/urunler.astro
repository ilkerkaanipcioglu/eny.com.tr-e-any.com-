---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { 
  Rat,
  Turtle,
  TreePine,
  Fish,
  Rabbit,
  Bird
} from '@lucide/astro';
const lang = 'tr' as const;
---
<Layout title="Ürünler | eny" lang={lang}>
    <Header lang={lang} />
    <!-- Hero -->
    <section class="relative pt-40 pb-32 bg-bg text-center overflow-hidden">
        <div class="absolute inset-0 bg-lime opacity-5 blur-[100px] -z-10 rounded-full w-[600px] h-[600px] left-1/2 -translate-x-1/2 top-0"></div>
        <div class="max-w-container mx-auto px-6 md:px-8 relative z-10">
            <span class="inline-block px-4 py-1.5 rounded-full bg-lime/10 text-accent-text-readable font-bold text-xs tracking-widest uppercase mb-6 font-mono">Finansal Teknoloji Seti</span>
            <h1 class="text-4xl md:text-7xl font-extrabold font-sans mb-8 text-text leading-tight tracking-tighter">
                Sisteminizle Entegre<br/>Finansal Altyapı.
            </h1>
            <p class="text-lg md:text-2xl text-text-70 font-sans font-light leading-relaxed max-w-3xl mx-auto w-full block">
                Banka entegrasyonlarından e-Devlet süreçlerine kadar tüm operasyonlarınızı, dış yazılımlara ihtiyaç duymadan doğrudan muhasebe sisteminizin kalbinden yönetin.
            </p>
        </div>
    </section>

    <!-- Products Grid -->
    <section class="py-24 bg-surface-container-lowest border-t border-outline-variant/10">
        <div class="max-w-7xl mx-auto px-8">
            
            <!-- Category: e-Belge & Mevzuat -->
            <div class="mb-16">
                <div class="flex items-center gap-4 mb-10 border-b border-border-main pb-4">
                    <div class="w-10 h-10 rounded-full bg-plum/10 text-plum flex items-center justify-center">
                        <Rat size={20} />
                    </div>
                    <h2 class="text-2xl font-bold font-sans text-text">e-Belge & Mevzuat Çözümleri</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- e-Fatura -->
                    <div class="glass-card p-8 rounded-2xl border border-border-main hover:border-plum transition-all group flex flex-col bg-bg3/30">
                        <h3 class="text-xl font-bold font-sans mb-3 text-text">e-Fatura & e-Arşiv</h3>
                        <p class="text-text-70 text-xs leading-relaxed mb-6 flex-grow">GİB standartlarında fatura oluşturma, gönderme ve saklama süreçlerinde tam otomasyon.</p>
                        <a href="/iletisim" class="text-plum font-mono text-[10px] tracking-widest uppercase hover:underline">Hemen İncele →</a>
                    </div>
                    <!-- e-Defter -->
                    <div class="glass-card p-8 rounded-2xl border border-border-main hover:border-plum transition-all group flex flex-col bg-bg3/30">
                        <h3 class="text-xl font-bold font-sans mb-3 text-text">e-Defter</h3>
                        <p class="text-text-70 text-xs leading-relaxed mb-6 flex-grow">Yevmiye ve Kebir defterlerinizi dijital ortamda mühürleyerek yasal geçerlilik kazandırın.</p>
                        <a href="/iletisim" class="text-plum font-mono text-[10px] tracking-widest uppercase hover:underline">Hemen İncele →</a>
                    </div>
                    <!-- e-İrsaliye -->
                    <div class="glass-card p-8 rounded-2xl border border-border-main hover:border-plum transition-all group flex flex-col bg-bg3/30">
                        <h3 class="text-xl font-bold font-sans mb-3 text-text">e-İrsaliye</h3>
                        <p class="text-text-70 text-xs leading-relaxed mb-6 flex-grow">Lojistik ve sevkiyat süreçlerinizi kağıtsız, anlık ve izlenebilir bir yapıya dönüştürün.</p>
                        <a href="/iletisim" class="text-plum font-mono text-[10px] tracking-widest uppercase hover:underline">Hemen İncele →</a>
                    </div>
                    <!-- TMS 29 -->
                    <div class="glass-card p-8 rounded-2xl border border-border-main hover:border-plum transition-all group flex flex-col bg-bg3/30">
                        <h3 class="text-xl font-bold font-sans mb-3 text-text">Enflasyon Muh.</h3>
                        <p class="text-text-70 text-xs leading-relaxed mb-6 flex-grow">TMS 29 standartlarında enflasyon düzeltmesi hesaplamalarını otomatize edin.</p>
                        <a href="/enflasyon-muhasebesi" class="text-plum font-mono text-[10px] tracking-widest uppercase hover:underline">Hemen İncele →</a>
                    </div>
                </div>
            </div>

            <!-- Category: e-Finans & Nakit Yönetimi -->
            <div class="mb-16">
                <div class="flex items-center gap-4 mb-10 border-b border-border-main pb-4">
                    <div class="w-10 h-10 rounded-full bg-lime/10 text-lime flex items-center justify-center">
                        <Turtle size={20} />
                    </div>
                    <h2 class="text-2xl font-bold font-sans text-text">e-Finans & Nakit Yönetimi</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <!-- Banka Hub -->
                    <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30 relative overflow-hidden">
                        <div class="absolute right-0 top-0 w-32 h-32 bg-lime/10 blur-2xl pointer-events-none"></div>
                        <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-Ekstre (Banka Hub)</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-8">Tüm banka hareketlerinizi tek ekrandan izleyin, AI ile otomatik muhasebe eşleştirmesi yapın.</p>
                        <a href="/e-ekstre" class="inline-flex items-center gap-2 text-lime font-mono text-xs tracking-widest uppercase hover:underline mt-auto">Detayları İncele <Rabbit size={14} /></a>
                    </div>
                    <!-- E-DBS -->
                    <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                        <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-DBS Sistemi</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-8">Bayi ağınızdaki tahsilat riskini banka garantisiyle e-DBS üzerinden yönetin.</p>
                        <a href="/e-dbs" class="inline-flex items-center gap-2 text-lime font-mono text-xs tracking-widest uppercase hover:underline mt-auto">Detayları İncele <Rabbit size={14} /></a>
                    </div>
                    <!-- E-POS -->
                    <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                        <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-POS Raporlama</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-8">Fiziksel ve sanal tüm POS akışlarınızı anlık takip edin, banka komisyonlarını denetleyin.</p>
                        <a href="/e-pos" class="inline-flex items-center gap-2 text-lime font-mono text-xs tracking-widest uppercase hover:underline mt-auto">Detayları İncele <Rabbit size={14} /></a>
                    </div>
                    <!-- E-Payment -->
                    <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                        <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-Ödeme (TÖS)</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-8">Toplu ödeme talimatlarını sisteminizden doğrudan bankalara güvenli şekilde iletin.</p>
                        <a href="/e-payment" class="inline-flex items-center gap-2 text-lime font-mono text-xs tracking-widest uppercase hover:underline mt-auto">Detayları İncele <Rabbit size={14} /></a>
                    </div>
                    <!-- E-Cashflow -->
                    <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                        <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-Nakit Akışı</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-8">Geleceğe yönelik nakit tahminlerini veriye dayalı senaryolarla raporlayın.</p>
                        <a href="/e-cashflow" class="inline-flex items-center gap-2 text-lime font-mono text-xs tracking-widest uppercase hover:underline mt-auto">Detayları İncele <Rabbit size={14} /></a>
                    </div>
                    <!-- Hazine -->
                    <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                        <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-Hazine & Risk</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-8">Döviz pozisyonu, faiz riski ve likidite analizini uçtan uca kontrol edin.</p>
                        <a href="/iletisim" class="inline-flex items-center gap-2 text-lime font-mono text-xs tracking-widest uppercase hover:underline mt-auto">e-KONUŞALIM <Rabbit size={14} /></a>
                    </div>
                </div>
            </div>

            <!-- Category: e-Ticaret & Operasyon -->
            <div>
                <div class="flex items-center gap-4 mb-10 border-b border-border-main pb-4">
                    <div class="w-10 h-10 rounded-full bg-accent-text-readable/10 text-accent-text-readable flex items-center justify-center">
                        <TreePine size={20} />
                    </div>
                    <h2 class="text-2xl font-bold font-sans text-text">e-Ticaret & Operasyon</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- e-Ticaret -->
                    <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col bg-bg3/30 relative overflow-hidden">
                        <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-Ticaret & Pazaryeri</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-8">Pazaryeri entegrasyonları, hak ediş takibi ve stok senkronizasyonunda tam otonom yapı.</p>
                        <a href="/e-ticaret" class="inline-flex items-center gap-2 text-accent-text-readable font-mono text-xs tracking-widest uppercase hover:underline mt-auto">Detayları İncele <Rabbit size={14} /></a>
                    </div>
                    <!-- e-Tahsilat -->
                    <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col bg-bg3/30 relative overflow-hidden">
                        <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-Tahsilat Platformu</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-8">B2B ve B2C tahsilatları online kanallar üzerinden güvenle yapın.</p>
                        <a href="/e-tahsilat" class="inline-flex items-center gap-2 text-accent-text-readable font-mono text-xs tracking-widest uppercase hover:underline mt-auto">Detayları İncele <Rabbit size={14} /></a>
                    </div>
                </div>
            </div>

        </div>
    </section>

            </div>
        </div>
    </section>

    <!-- eny Insights Series -->
    <section class="py-24 bg-surface-container-lowest border-t border-outline-variant/10">
        <div class="max-w-7xl mx-auto px-8">
            <div class="bg-surface-container-low p-10 md:p-14 rounded-3xl border border-outline-variant/20 relative overflow-hidden">
                <div class="absolute w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none -right-10 -bottom-10"></div>
                <Bird size={64} class="text-primary/20 mb-6 block" />
                <h3 class="text-sm font-bold tracking-widest text-primary uppercase mb-6">KURUMSAL FİNANSAL RAPORLAMA</h3>
                <p class="text-xl md:text-2xl text-on-background font-light leading-relaxed mb-8 relative z-10 italic">
                    "Birden fazla tüzel kişilik, bağlı ortaklık veya coğrafyada faaliyet gösteren organizasyonlar için finansal kapanış, genellikle finans takvimininin en emek yoğun sürecidir. Şirketlerarası eliminasyonlar, kur çevrimi ve çok standartlı raporlama gereksinimleri, haftalar süren ve yine de manuel müdahale gerektiren bir sürece dönüşebilir. Modern ERP sistemleri içine doğal olarak entegre edilmiş kurumsal raporlama araçları, konsolidasyon mantığını doğrudan merkezi deftere gömerek bu sorunu ele alır. 2025 ve 2026 sürümlerinde tanıtılan yeni kural motorları, en karmaşık dağıtım ve eliminasyon senaryolarını otomatize ederek çevrimdışı çalışma kitaplarına ve konsolidasyon uzmanlarına olan bağımlılığı azaltır. Merkezi Finans mimarisi bu yapıyı heterojen ortamlara genişletir — birden fazla yazılım sistemi işleten organizasyonlar, yan kuruluşların sistem geçişi gerektirmeksizin finansal verileri tek bir merkezde toplayabilir. Sonuç: tüm organizasyonda tek, denetlenebilir bir finansal gerçek — ve bu gerçeğe gerçek zamanlı erişim."
                </p>
                <div class="flex items-center gap-4 relative z-10 mt-8 pt-8 border-t border-outline-variant/10">
                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <Fish size={14} />
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-on-background">eny Insight Series</h4>
                        <span class="text-xs text-on-surface-variant uppercase tracking-widest">Finansal Mimari Vizyonu</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- CTA -->
    <section class="py-24 bg-bg">
        <div class="max-w-4xl mx-auto px-8">
            <div class="bg-lime rounded-3xl p-12 md:p-16 text-center text-black shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
                <h2 class="text-3xl md:text-5xl font-extrabold font-sans mb-6 relative z-10 tracking-tighter">Kendi Ekosisteminizi Kurun</h2>
                <p class="text-black/70 text-lg mb-10 font-sans font-light relative z-10">
                    Sistem entegrasyonu ve finansal mimari analizi için uzmanlarımızla iletişime geçin. İşletmenize özel yol haritasını birlikte çıkaralım.
                </p>
                <a href="/iletisim" class="inline-block bg-black text-white px-10 py-4 rounded-xl font-bold hover:shadow-lg hover:-translate-y-1 transition-all relative z-10 font-mono text-sm tracking-widest uppercase">
                    e-KONUŞALIM
                </a>
            </div>
        </div>
    </section>
    <Footer lang={lang} />
</Layout>
