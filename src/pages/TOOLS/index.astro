---
import Layout from '../../layouts/Layout.astro';
import EmailAuthGate from '../../components/tools/EmailAuthGate.astro';
---

<Layout title="İç Araçlar Merkezi">
  <EmailAuthGate />
  
  <main class="min-h-screen bg-surface text-text pt-32 pb-20 relative overflow-hidden">
    <!-- Eny Brand Decorators -->
    <div class="absolute top-0 right-0 w-[50vw] h-[50vh] bg-lime/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="container mx-auto px-6 max-w-7xl relative z-10">
      
      <!-- Header -->
      <div class="mb-16">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-lime/20 bg-lime/5 mb-6 text-lime font-mono text-sm uppercase">
          <span class="material-symbols-outlined text-lg">admin_panel_settings</span>
          Eny Tools
        </div>
        <h1 class="font-syne font-bold text-5xl md:text-7xl tracking-tight mb-6">
          Şirket İçi Operasyon <br/>
          <span class="text-text-40 animate-pulse">Merkezi</span>
        </h1>
        <p class="text-text-60 text-lg md:text-xl font-mono max-w-2xl leading-relaxed">
          Harezm ve Eny ekosisteminin tüm operasyonel, dönüştürme ve teknik araçları burada toplanmıştır.
        </p>
      </div>

      <!-- Tools Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- SVG Vectorizer Tool Card -->
        <a href="/TOOLS/svg-olusturucu" class="group relative bg-[#131514] border border-border p-8 rounded-3xl overflow-hidden shadow-2xl transition-all duration-300 hover:border-lime/50 hover:shadow-[0_0_40px_-10px_rgba(208,253,23,0.15)] flex flex-col h-full">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-lime to-lime bg-[length:0%_100%] bg-no-repeat group-hover:bg-[length:100%_100%] transition-all duration-500"></div>
          
          <div class="w-14 h-14 bg-surface border border-border rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="material-symbols-outlined text-lime text-2xl">draw</span>
          </div>

          <h3 class="font-syne font-bold text-2xl mb-3">SVG Dönüştürücü</h3>
          <p class="text-text-60 font-mono text-sm leading-relaxed mb-8 flex-grow">
            Yapay zeka ile üretilen raster (.png/.jpg) ikonları "Siyah, Beyaz ve Accent" paletinden matematiksel SVG (vektör) path'lerine çevirir. CSS renk yapısına uyarlar. 
          </p>

          <div class="flex items-center text-lime font-mono text-sm mt-auto">
            Aracı Başlat
            <span class="material-symbols-outlined ml-2 group-hover:translate-x-2 transition-transform duration-300">arrow_right_alt</span>
          </div>
        </a>

      </div>

    </div>
  </main>
</Layout>
