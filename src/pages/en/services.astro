---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en' as const;
---
<Layout title="Services | eny" lang={lang}>
    <Header lang={lang} />
    <!-- HERO -->
    <header class="relative pt-40 pb-24 md:pt-48 md:pb-32 bg-bg overflow-hidden border-b border-border-main">
        <div class="absolute inset-0 bg-lime opacity-5 blur-[120px] -z-10 rounded-full w-[800px] h-[800px] right-0 top-0 pointer-events-none"></div>

        <div class="max-w-container mx-auto px-8 md:px-12 relative z-10">
            <div class="w-full md:w-3/4 animate-fade-up">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-lime/10 text-accent-text-readable text-[10px] font-mono tracking-widest uppercase mb-8 border border-lime/20">
                    <span class="material-symbols-outlined text-sm">architecture</span>
                    FINANCIAL TECHNOLOGY SERVICES
                </span>
                
                <h1 class="text-4xl md:text-7xl font-extrabold font-sans mb-6 text-text leading-tight tracking-tighter">
                    Automating Your<br/><span class="text-accent-text-readable">Financial Systems.</span>
                </h1>
                <p class="text-text-70 text-body-lg max-w-2xl font-sans font-light leading-relaxed mb-10">
                    We simplify your financial operations with AI and modern system architecture, securing your cross-border transformation strategy.
                </p>
                
                <div class="flex flex-wrap gap-4">
                    <a href="#services-grid" class="bg-lime text-black px-8 py-4 rounded-lg font-bold font-mono text-xs uppercase tracking-widest hover:bg-white transition-all inline-flex items-center gap-2">
                        Explore Expertise
                        <span class="material-symbols-outlined text-sm">arrow_downward</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- SERVICES BENTO GRID -->
    <section id="services-grid" class="py-24 md:py-32 bg-bg2 relative border-b border-border-main">
        <div class="max-w-container mx-auto px-8 md:px-12">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <h2 class="text-3xl md:text-5xl font-extrabold font-sans mb-4 text-text tracking-tighter">Strategic Focus Areas</h2>
                    <div class="h-1.5 w-24 bg-lime"></div>
                </div>
                <p class="text-text-70 max-w-md text-sm font-sans font-light leading-relaxed">
                    We optimize high-volume financial processes and establish data-driven decision-making algorithms.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[auto]">

                <!-- Kategori 1 Başlığı -->
                <div class="md:col-span-12 mt-4 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-bold font-sans text-accent-text-readable flex items-center gap-3">
                        <span class="material-symbols-outlined">account_tree</span>
                        1. Enterprise Platform Solutions
                    </h3>
                </div>

<!-- Card 1: Financial Architecture / Material Ledger (Merged) -->
                <div class="md:col-span-8 md:row-span-2 bg-bg3/50 p-10 rounded-2xl flex flex-col justify-between text-text relative overflow-hidden group border border-border-main hover:border-lime transition-all">
                    <div class="absolute right-0 top-0 w-1/2 h-full bg-lime/10 blur-[100px] pointer-events-none opacity-20 transition-opacity group-hover:opacity-40"></div>
                    <div class="relative z-10 w-full">
                        <div class="flex justify-between items-start mb-6">
                            <span class="material-symbols-outlined text-5xl text-lime group-hover:scale-110 transition-transform">account_balance</span>
                            <span class="px-3 py-1 bg-lime/20 text-lime rounded-full text-[10px] font-mono font-bold tracking-[0.1em] uppercase border border-lime/30">Flagship</span>
                        </div>
                        <h3 class="text-3xl font-extrabold font-sans mb-3 text-text">Financial Accounting & Cost Management</h3>
                        <p class="text-text-70 text-sm mb-8 font-sans font-light max-w-lg">We provide enterprise accounting, cost control, and actual costing in a single integrated architectural framework.</p>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-6 text-white/90 text-sm font-light">
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-3">FI — Finansal Muhasebe</p>
                                <ul class="space-y-2">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Defter-i Kebir (New GL)</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Borçlar & Alacaklar (AP/AR)</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Duran Varlık Yönetimi</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Banka Muhasebesi</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Vergi & e-Dönüşüm</li>
                                </ul>
                            </div>
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-3">CO — Kontroling</p>
                                <ul class="space-y-2">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Maliyet Merkezi </li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Dahili Sipariş</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Ürün Maliyetlendirme</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Kârlılık Analizi (CO-PA)</li>
                                </ul>
                            </div>
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-3">Material Ledger</p>
                                <ul class="space-y-2">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Gerçek Maliyet</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Çoklu Para Birimi Değerleme</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Stok Yeniden Değerleme</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                
<!-- Card 5: Modern ERP -->
                <div class="glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-lime transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-6 group-hover:border-lime transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-lime transition-colors">rocket_launch</span>
                        </div>
                        <h3 class="text-xl font-bold font-sans mb-3 text-text group-hover:text-lime transition-colors">Digital ERP Transformation</h3>
                        <p class="text-text-70 text-sm font-sans font-light leading-relaxed mb-6">Seamless transition to next-generation cloud systems and the modern ERP world with Greenfield and Brownfield approaches.</p>
                    </div>
                    <a href="/en/s4hana" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest text-text-main group-hover:text-lime transition-colors">View Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                
<!-- Card 6: PS & BPC -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">schema</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Project & Investment Management</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">We integrate investment management, project planning, and budget consolidation processes into a single core.</p>
                    </div>
                </div>

                
<!-- Card 8: Real Estate Management -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">real_estate_agent</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Real Estate Portfolio Management</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">End-to-end solution with commercial real estate management, lease contracts, maintenance, and financial integration.</p>
                    </div>
                    <a href="/en/contact" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                
<!-- Card 12: Cash Management -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">account_balance_wallet</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Cash and Liquidity Management</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Achieve 100% cash visibility, manage your bank accounts and liquidity forecasts in real-time.</p>
                    </div>
                    <a href="/en/e-dbs" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                
<!-- Card 13: Treasury Management (Feature Card) -->
                <div class="md:col-span-12 md:row-span-1 glass-card p-10 md:p-12 rounded-2xl flex flex-col md:flex-row justify-between items-center group hover:border-lime transition-all duration-300 border-l-4 border-l-transparent hover:border-l-lime">
                    <div class="md:w-2/3 relative z-10">
                        <div class="w-16 h-16 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-8 group-hover:border-lime transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-lime transition-colors text-3xl">monitoring</span>
                        </div>
                        <h3 class="text-3xl font-extrabold font-sans mb-4 text-text group-hover:text-lime transition-colors">Treasury and Risk Management</h3>
                        <p class="text-text-70 font-sans font-light leading-relaxed md:pr-12">Optimize Working Capital, Achieve 30% Increase in Cash Efficiency. Manage liquidity, payments, and risks from a single center on the financial data fabric.</p>
                    </div>
                    <div class="md:w-1/3 flex md:justify-end mt-8 md:mt-0 relative z-10">
                        <a href="/en/services" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest bg-bg border border-border-main text-text-main hover:bg-lime hover:text-black hover:border-lime px-8 py-4 rounded-lg transition-all duration-300 whitespace-nowrap">Examine Now <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                    </div>
                </div>
            
                <!-- Card: SAP Sabit Kıymet -->
                <div class="md:col-span-6 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">precision_manufacturing</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Asset and Fixed Asset Management</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Value your company's largest assets with millimeter precision, automate your depreciation plans.</p>
                    </div>
                    <a href="/en/contact" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Card: SAP Finansal Konsolidasyon -->
                <div class="md:col-span-6 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">table_chart</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Financial Consolidation and Grouping</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Measure the profitability of your holding and group companies at a glance with real figures, reduce the process from months to days.</p>
                    </div>
                    <a href="/en/contact" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Kategori 2 Başlığı -->
                <div class="md:col-span-12 mt-12 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-bold font-sans text-lime flex items-center gap-3">
                        <span class="material-symbols-outlined">receipt_long</span>
                        2. e-Transformation & Digitalization
                    </h3>
                </div>

<!-- Card 9: SAP & OpenText -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">auto_awesome</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Digital Archive and Invoice Automation</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">AI-powered document management, full automation in invoice processes, and system integration for digital transformation.</p>
                    </div>
                    <a href="/en/contact" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Card: KDV İade -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">autorenew</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">KDV İade Sistemi</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Create your VAT refund lists with 100% compliance with regulatory formats through your system in one click.</p>
                    </div>
                    <a href="/en/contact" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">storefront</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">e-Commerce & Marketplace</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Manage order flow, stock synchronization, and marketplace commission processes from a single center.</p>
                    </div>
                    <a href="/en/e-commerce" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>


                

                <!-- Kategori 3 Başlığı -->
                <div class="md:col-span-12 mt-12 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-bold font-sans text-lime flex items-center gap-3">
                        <span class="material-symbols-outlined">currency_exchange</span>
                        3. Financial Automation & Bank Connectivity
                    </h3>
                </div>

                <!-- Card: E-DBS -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">account_balance</span>
                        </div>
                        <h3 class="text-xl font-bold font-sans mb-3 text-text group-hover:text-plum transition-colors">E-DBS — Direct Debit System</h3>
                        <p class="text-text-70 text-sm font-sans font-light leading-relaxed mb-6">Manage all DBS transactions across your dealer and customer network from a single panel, fully integrated with your ERP.</p>
                    </div>
                    <a href="/en/e-dbs" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest text-text-main group-hover:text-plum transition-colors">View Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Card: E-Statement -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">account_tree</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">E-Statement & Open Banking</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Manage all your bank accounts from one screen, transfer transactions to your ERP instantly.</p>
                    </div>
                    <a href="/en/e-statement" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Card: E-POS -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">payments</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">E-POS Tracking & Reporting</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Monitor all your physical and virtual POS transactions in one panel, automatically transfer to ERP.</p>
                    </div>
                    <a href="/en/e-pos" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Card: E-Payment -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">hub</span>
                        </div>
                        <h3 class="text-xl font-bold font-sans mb-3 text-text group-hover:text-plum transition-colors">E-Payment (Bulk Payment)</h3>
                        <p class="text-text-70 text-sm font-sans font-light leading-relaxed mb-6">Manage your bulk payment processes from a single center, send instructions to all banks simultaneously.</p>
                    </div>
                    <a href="/en/e-payment" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest text-text-main group-hover:text-plum transition-colors">View Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Card: E-Cash Flow -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">analytics</span>
                        </div>
                        <h3 class="text-xl font-bold font-sans mb-3 text-text group-hover:text-plum transition-colors">E-Cash Flow Management</h3>
                        <p class="text-text-70 text-sm font-sans font-light leading-relaxed mb-6">Track all financial movements in real-time, manage liquidity with AI-powered forecasting.</p>
                    </div>
                    <a href="/en/e-cashflow" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest text-text-main group-hover:text-plum transition-colors">View Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Card: E-Collection -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <span class="material-symbols-outlined text-text-main group-hover:text-plum transition-colors">account_balance_wallet</span>
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">E-Collection Platform</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Collect online payments from customers and dealers in seconds with 3D Secure assurance.</p>
                    </div>
                    <a href="/en/e-collection" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Examine Details <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>

                <!-- Card: TMS 29 -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
