---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/utils';
const lang = 'en' as const;
---
<Layout title={`${t('navContact', lang)} | eny`} lang={lang}>
    <Header lang={lang} />
    
    <main class="pt-40 pb-32 px-8 bg-bg relative overflow-hidden">
        <!-- Background Accents -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-plum)_0%,_transparent_50%)] opacity-5 pointer-events-none"></div>
        <div class="absolute -right-40 top-1/4 w-[600px] h-[600px] bg-teal/5 blur-[120px] -z-10 rounded-full"></div>

        <div class="max-w-container mx-auto relative z-10">
            <div class="max-w-4xl mb-20 animate-fade-up">
                <span class="inline-block px-4 py-1.5 rounded-full bg-plum/10 text-plum font-bold text-[10px] tracking-widest uppercase mb-6 border border-plum/20">{t('navContact', lang)}</span>
                <h1 class="display-lg text-4xl md:text-7xl font-medium mb-8 leading-[1.1]">{t('contactTitle', lang)}</h1>
                <p class="text-lg md:text-xl text-text-70 font-light leading-relaxed max-w-2xl">
                    {t('contactSubtitle', lang)}
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
                
                <!-- Left: Formspree AJAX Form -->
                <div class="lg:col-span-7 animate-fade-up" style="animation-delay: 200ms;">
                    <div class="glass-card p-8 md:p-12 rounded-3xl border border-border-main bg-bg2/50 relative overflow-hidden">
                        
                        <div id="form-success" class="hidden text-center py-12 animate-fade-in">
                            <div class="w-20 h-20 bg-teal/10 text-teal rounded-full flex items-center justify-center mx-auto mb-6">
                                <span class="material-symbols-outlined text-4xl">check_circle</span>
                            </div>
                            <h3 class="text-2xl font-medium mb-4">{t('formSuccess', lang)}</h3>
                            <button onclick="window.location.reload()" class="text-plum text-sm font-medium hover:underline">Send another message</button>
                        </div>

                        <form id="contact-form" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label for="name" class="text-xs font-medium text-text-40 uppercase tracking-widest">{t('formName', lang)}</label>
                                    <input type="text" id="name" name="name" required class="w-full bg-bg border border-border-main rounded-xl px-4 py-4 text-text-main focus:border-plum outline-none transition-all placeholder:text-text-40" placeholder="Full Name" data-fs-field />
                                </div>
                                <div class="space-y-2">
                                    <label for="email" class="text-xs font-medium text-text-40 uppercase tracking-widest">{t('formEmail', lang)}</label>
                                    <input type="email" id="email" name="email" required class="w-full bg-bg border border-border-main rounded-xl px-4 py-4 text-text-main focus:border-plum outline-none transition-all placeholder:text-text-40" placeholder="corporate@company.com" data-fs-field />
                                </div>
                            </div>
                            
                            <div class="space-y-2">
                                <label for="subject" class="text-xs font-medium text-text-40 uppercase tracking-widest">{t('formSubject', lang)}</label>
                                <input type="text" id="subject" name="subject" required class="w-full bg-bg border border-border-main rounded-xl px-4 py-4 text-text-main focus:border-plum outline-none transition-all placeholder:text-text-40" placeholder="Project Details, Roll-out, Consulting..." data-fs-field />
                            </div>

                            <div class="space-y-2">
                                <label for="message" class="text-xs font-medium text-text-40 uppercase tracking-widest">{t('formMessage', lang)}</label>
                                <textarea id="message" name="message" required rows="5" class="w-full bg-bg border border-border-main rounded-xl px-4 py-4 text-text-main focus:border-plum outline-none transition-all placeholder:text-text-40 resize-none" placeholder="How can we help you?" data-fs-field></textarea>
                            </div>

                            <div id="form-error" class="hidden p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-500 text-sm text-center" data-fs-error>
                                {t('formError', lang)}
                            </div>

                            <button type="submit" id="submit-btn" class="w-full bg-plum text-white py-5 rounded-xl font-medium hover:bg-plum-hover transition-all flex items-center justify-center gap-3 group disabled:opacity-50 disabled:cursor-not-allowed" data-fs-submit-btn>
                                <span>{t('formSubmit', lang)}</span>
                                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Right: Founders Direct Access -->
                <div class="lg:col-span-5 space-y-12 animate-fade-up" style="animation-delay: 400ms;">
                    <div>
                        <h2 class="text-3xl font-medium mb-4">{t('directAccess', lang)}</h2>
                        <p class="text-text-70 font-light leading-relaxed mb-10">
                            {t('contactDirectDesc', lang)}
                        </p>
                        
                        <div class="contact-cards-container space-y-12">
                            <!-- Çiğdem Fener Business Card -->
                            <div class="business-card-wrapper group">
                                <div class="business-card bg-bg2 border border-border-main rounded-xl overflow-hidden shadow-2xl transition-all duration-500 group-hover:-translate-y-2 group-hover:shadow-lime/10">
                                    <div class="card-front bg-lime p-6 h-24 flex items-center justify-between relative overflow-hidden">
                                        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_white_0%,_transparent_70%)]"></div>
                                        <div class="flex items-center gap-3 relative z-10">
                                            <img src="/images/logo/eny_icon_black.png" alt="eny" class="h-10 w-auto" />
                                            <span class="text-black font-extrabold tracking-tighter text-2xl">eny<span class="text-white">.</span></span>
                                        </div>
                                        <div class="text-[10px] font-bold text-black/40 tracking-widest uppercase relative z-10">Co-Founder</div>
                                    </div>
                                    <div class="card-back p-8 bg-surface">
                                        <div class="flex justify-between items-start mb-6">
                                            <div>
                                                <h3 class="text-2xl font-bold text-text-main mb-1">Çiğdem Fener</h3>
                                                <p class="text-xs text-accent-text-readable font-mono uppercase tracking-widest">Financial Technology & Strategy</p>
                                            </div>
                                            <div class="flex gap-3">
                                                <a href="https://www.linkedin.com/in/%C3%A7i%C4%9Fdem-fener-5a932561/" target="_blank" class="w-10 h-10 rounded-full bg-bg2 flex items-center justify-center text-text-70 hover:text-lime transition-all border border-border-main hover:border-lime/50">
                                                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                                                </a>
                                                <a href="https://wa.me/905302394989" target="_blank" class="text-text-70 hover:text-green-500 transition-all border border-border-main hover:border-green-500/50">
                                                    <span class="material-symbols-outlined text-xl">chat</span>
                                                </a>
                                            </div>
                                        </div>
                                        <div class="space-y-2 text-xs font-mono text-text-40">
                                            <div class="flex items-center gap-2">
                                                <span class="text-accent-text-readable">E:</span> cf@eny.com.tr
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <span class="text-accent-text-readable">P:</span> +90 530 239 49 89
                                            </div>
                                            <div class="pt-4 flex items-center justify-between border-t border-border-main mt-4">
                                                <span class="tracking-widest opacity-30 italic font-sans italic lowercase">www.eny.com.tr</span>
                                                <span class="text-[10px] font-bold text-lime/50 uppercase">eny ecosystem</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- İlker Kaan İpcioğlu Business Card -->
                            <div class="business-card-wrapper group">
                                <div class="business-card bg-bg2 border border-border-main rounded-xl overflow-hidden shadow-2xl transition-all duration-500 group-hover:-translate-y-2 group-hover:shadow-lime/10">
                                    <div class="card-front bg-[#1A1C1F] p-6 h-24 flex items-center justify-between relative overflow-hidden">
                                        <div class="absolute inset-0 opacity-5 bg-[radial-gradient(circle_at_center,_var(--lime)_0%,_transparent_70%)]"></div>
                                        <div class="flex items-center gap-3 relative z-10">
                                            <img src="/images/logo/eny_icon.png" alt="eny" class="h-10 w-auto" />
                                            <span class="text-white font-extrabold tracking-tighter text-2xl">eny<span class="text-lime">.</span></span>
                                        </div>
                                        <div class="text-[10px] font-bold text-lime/60 tracking-widest uppercase relative z-10">Co-Founder</div>
                                    </div>
                                    <div class="card-back p-8 bg-surface">
                                        <div class="flex justify-between items-start mb-6">
                                            <div>
                                                <h3 class="text-2xl font-bold text-text-main mb-1">İlker Kaan İpcioğlu</h3>
                                                <p class="text-xs text-accent-text-readable font-mono uppercase tracking-widest">Financial Architecture & Tech</p>
                                            </div>
                                            <div class="flex gap-3">
                                                <a href="https://www.linkedin.com/in/ilkerkaan" target="_blank" class="w-10 h-10 rounded-full bg-bg2 flex items-center justify-center text-text-70 hover:text-lime transition-all border border-border-main hover:border-lime/50">
                                                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                                                </a>
                                                <a href="https://wa.me/905332399875" target="_blank" class="text-text-70 hover:text-green-500 transition-all border border-border-main hover:border-green-500/50">
                                                    <span class="material-symbols-outlined text-xl">chat</span>
                                                </a>
                                            </div>
                                        </div>
                                        <div class="space-y-2 text-xs font-mono text-text-40">
                                            <div class="flex items-center gap-2">
                                                <span class="text-accent-text-readable">E:</span> iki@eny.com.tr
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <span class="text-accent-text-readable">P:</span> +90 533 239 98 75
                                            </div>
                                            <div class="pt-4 flex items-center justify-between border-t border-border-main mt-4">
                                                <span class="tracking-widest opacity-30 italic font-sans italic lowercase">www.eny.com.tr</span>
                                                <span class="text-[10px] font-bold text-lime/50 uppercase">eny ecosystem</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Offices -->
                    <div class="grid grid-cols-2 lg:grid-cols-3 gap-6 pt-8 border-t border-border-main">
                        <div class="space-y-3">
                            <h3 class="text-[10px] font-bold text-text-40 uppercase tracking-widest">{t('officeIstanbul', lang)}</h3>
                            <a href="https://wa.me/905332388975" target="_blank" class="flex items-center gap-2 text-text-main hover:text-green-500 transition-colors group">
                                <span class="material-symbols-outlined text-lg opacity-50 group-hover:opacity-100">chat</span>
                                <span class="text-xs font-medium">WhatsApp</span>
                            </a>
                        </div>
                        <div class="space-y-3">
                            <h3 class="text-[10px] font-bold text-text-40 uppercase tracking-widest">{t('officeSakarya', lang)}</h3>
                            <a href="https://wa.me/905332388975" target="_blank" class="flex items-center gap-2 text-text-main hover:text-green-500 transition-colors group">
                                <span class="material-symbols-outlined text-lg opacity-50 group-hover:opacity-100">chat</span>
                                <span class="text-xs font-medium">WhatsApp</span>
                            </a>
                        </div>
                        <div class="space-y-3">
                            <h3 class="text-[10px] font-bold text-text-40 uppercase tracking-widest">{t('officeKonya', lang)}</h3>
                            <a href="https://wa.me/905332388975" target="_blank" class="flex items-center gap-2 text-text-main hover:text-green-500 transition-colors group">
                                <span class="material-symbols-outlined text-lg opacity-50 group-hover:opacity-100">chat</span>
                                <span class="text-xs font-medium">WhatsApp</span>
                            </a>
                        </div>
                        <div class="space-y-3">
                            <h3 class="text-[10px] font-bold text-text-40 uppercase tracking-widest">{t('officeNairobi', lang)}</h3>
                            <a href="https://wa.me/254721746268" target="_blank" class="flex items-center gap-2 text-text-main hover:text-green-500 transition-colors group">
                                <span class="material-symbols-outlined text-lg opacity-50 group-hover:opacity-100">chat</span>
                                <span class="text-xs font-medium">WhatsApp</span>
                            </a>
                        </div>
                        <div class="space-y-3">
                            <h3 class="text-[10px] font-bold text-text-40 uppercase tracking-widest">{t('officeMozambique', lang)}</h3>
                            <a href="https://wa.me/254721746268" target="_blank" class="flex items-center gap-2 text-text-main hover:text-green-500 transition-colors group">
                                <span class="material-symbols-outlined text-lg opacity-50 group-hover:opacity-100">chat</span>
                                <span class="text-xs font-medium">WhatsApp</span>
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <Footer lang={lang} />

    <!-- Formspree Scripts -->
    <script is:inline>
      window.formspree = window.formspree || function () { (formspree.q = formspree.q || []).push(arguments); };
      
      const setupForm = () => {
        const form = document.querySelector('#contact-form');
        const successDiv = document.querySelector('#form-success');
        const errorDiv = document.querySelector('#form-error');

        if (form) {
            formspree('initForm', { 
                formElement: '#contact-form', 
                formId: 'xykbljdr',
                onSuccess: () => {
                    form.classList.add('hidden');
                    successDiv.classList.remove('hidden');
                },
                onError: (errors) => {
                    errorDiv.classList.remove('hidden');
                }
            });
        }
      };

      document.addEventListener('astro:page-load', setupForm);
      setupForm();
    </script>
    <script src="https://unpkg.com/@formspree/ajax@1" defer is:inline></script>
</Layout>

