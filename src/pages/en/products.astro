---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const lang = 'en' as const;
---
<Layout title="Products | eny" lang={lang}>
    <Header lang={lang} />
    <!-- Hero -->
    <section class="relative pt-40 pb-32 bg-bg text-center overflow-hidden">
        <div class="absolute inset-0 bg-lime opacity-5 blur-[100px] -z-10 rounded-full w-[600px] h-[600px] left-1/2 -translate-x-1/2 top-0"></div>
        <div class="max-w-container mx-auto px-8 relative z-10">
            <span class="inline-block px-4 py-1.5 rounded-full bg-lime/10 text-accent-text-readable font-bold text-xs tracking-widest uppercase mb-6 font-mono">Financial Technology Suite</span>
            <h1 class="text-5xl md:text-7xl font-extrabold font-sans mb-8 text-text leading-tight tracking-tighter">
                Integrated Financial<br/>Infrastructure.
            </h1>
            <p class="text-xl md:text-2xl text-text-70 font-sans font-light leading-relaxed max-w-3xl mx-auto w-full block">
                Manage all your operations, from bank integrations to e-Government packages, directly from the heart of your accounting architecture without the need for external software.
            </p>
        </div>
    </section>

    <!-- Products Grid -->
    <section class="py-24 bg-surface-container-lowest border-t border-outline-variant/10">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                
                <!-- 1 -->
                <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                    <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex justify-center items-center mb-8 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">payments</span>
                    </div>
                    <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-Collection</h3>
                    <p class="text-text-70 text-sm leading-relaxed mb-8 flex-grow">
                        Digitize your collection processes with virtual POS integrations. Incoming payments are automatically matched and accounted for within the financial module.
                    </p>
                    <a href="/en/e-collection" class="inline-flex items-center gap-2 text-accent-text-readable font-mono text-sm tracking-wide group-hover:underline">
                        VIEW DETAILS <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>

                <!-- 2 -->
                <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full lg:col-span-2 relative overflow-hidden bg-bg3/30">
                    <div class="absolute right-0 top-0 w-64 h-64 bg-lime/20 blur-3xl group-hover:bg-lime/30 transition-colors pointer-events-none opacity-20"></div>
                    <div class="w-16 h-16 rounded-2xl bg-lime text-black flex justify-center items-center mb-8 group-hover:scale-110 transition-transform relative z-10">
                        <span class="material-symbols-outlined text-3xl">hub</span>
                    </div>
                    <h3 class="text-3xl font-bold font-sans mb-4 text-text relative z-10">Bank Hub (Multi-Bank Connectivity)</h3>
                    <p class="text-text-70 text-lg leading-relaxed mb-8 max-w-2xl relative z-10">
                        Stop logging into separate bank portals. Perform all your account movements, MT940 reconciliations, and real-time balance views from a single screen, directly through your system. Automated matching powered by AI.
                    </p>
                    <a href="/en/e-statement" class="inline-flex items-center gap-2 text-lime font-mono text-sm tracking-wide group-hover:underline mt-auto relative z-10">
                        VIEW DETAILS <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>

                <!-- 3 -->
                <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                    <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex justify-center items-center mb-8 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">account_balance</span>
                    </div>
                    <h3 class="text-2xl font-bold font-sans mb-4 text-text">E-DBS</h3>
                    <p class="text-text-70 text-sm leading-relaxed mb-8 flex-grow">
                        Manage your multi-bank Direct Debit System processes from a single panel and secure your cash flow across your dealer network.
                    </p>
                    <a href="/en/e-dbs" class="inline-flex items-center gap-2 text-lime font-mono text-sm tracking-wide group-hover:underline">
                        VIEW DETAILS <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>

                <!-- 4 -->
                <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                    <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex justify-center items-center mb-8 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">hub</span>
                    </div>
                    <h3 class="text-2xl font-bold font-sans mb-4 text-text">E-Payment (Bulk)</h3>
                    <p class="text-text-70 text-sm leading-relaxed mb-8 flex-grow">
                        Execute multiple payment transactions simultaneously across different banks and accounts, and manage approval flows directly from your ERP.
                    </p>
                    <a href="/en/e-payment" class="inline-flex items-center gap-2 text-lime font-mono text-sm tracking-wide group-hover:underline">
                        VIEW DETAILS <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>

                <!-- 5 -->
                <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                    <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex justify-center items-center mb-8 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">gavel</span>
                    </div>
                    <h3 class="text-2xl font-bold font-sans mb-4 text-text">e-Government Series</h3>
                    <p class="text-text-70 text-sm leading-relaxed mb-8 flex-grow">
                        e-Invoice, e-Ledger, e-Delivery, and e-Archive processes with 100% compliance to regulatory standards and seamless system integration.
                    </p>
                    <a href="/en/contact" class="inline-flex items-center gap-2 text-lime font-mono text-sm tracking-wide group-hover:underline">
                        e-TALK <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>

                <!-- 6 -->
                <div class="glass-card p-10 rounded-3xl border border-border-main hover:border-lime transition-all group flex flex-col h-full bg-bg3/30">
                    <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex justify-center items-center mb-8 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">analytics</span>
                    </div>
                    <h3 class="text-2xl font-bold font-sans mb-4 text-text">E-Cash Flow</h3>
                    <p class="text-text-70 text-sm leading-relaxed mb-8 flex-grow">
                        Monitor all financial movements in real-time, generate future cash flow projections and simulate various financial scenarios.
                    </p>
                    <a href="/en/e-cashflow" class="inline-flex items-center gap-2 text-lime font-mono text-sm tracking-wide group-hover:underline">
                        VIEW DETAILS <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>

            </div>
        </div>
    </section>

    <!-- eny Insights Series -->
    <section class="py-24 bg-surface-container-lowest border-t border-outline-variant/10">
        <div class="max-w-7xl mx-auto px-8">
            <div class="bg-surface-container-low p-10 md:p-14 rounded-3xl border border-outline-variant/20 relative overflow-hidden">
                <div class="absolute w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none -right-10 -bottom-10"></div>
                <span class="material-symbols-outlined text-6xl text-primary/20 mb-6 block">format_quote</span>
                <h3 class="text-sm font-bold tracking-widest text-primary uppercase mb-6">06 · ENTERPRISE FINANCIAL REPORTING</h3>
                <p class="text-xl md:text-2xl text-on-background font-light leading-relaxed mb-8 relative z-10 italic">
                    "For organizations operating across multiple legal entities, subsidiaries, or geographies, financial close is typically the most labor-intensive process in the finance calendar. Intercompany eliminations, currency translations, and multi-GAAP reporting requirements can turn into a weeks-long process still requiring manual intervention. Modern reporting tools, natively integrated into newer ERP architectures, address this by embedding consolidation logic directly into the central ledger. The new rule engines introduced in recent releases automate the most complex allocation and elimination scenarios, reducing dependency on offline workbooks and consolidation specialists. Central Finance architectures extend this to heterogeneous environments—organizations running multiple software systems can aggregate financial data into a single core without requiring subsidiary system migrations. The outcome: a single, auditable financial truth across the entire organization—and real-time access to that truth."
                </p>
                <div class="flex items-center gap-4 relative z-10 mt-8 pt-8 border-t border-outline-variant/10">
                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-sm">architecture</span>
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-on-background">eny Insight Series</h4>
                        <span class="text-xs text-on-surface-variant uppercase tracking-widest">Financial Architecture Vision</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- CTA -->
    <section class="py-24 bg-bg">
        <div class="max-w-4xl mx-auto px-8">
            <div class="bg-lime rounded-3xl p-12 md:p-16 text-center text-black shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
                <h2 class="text-3xl md:text-5xl font-extrabold font-sans mb-6 relative z-10 tracking-tighter">Build Your Own Ecosystem</h2>
                <p class="text-black/70 text-lg mb-10 font-sans font-light relative z-10">
                    Contact our experts for a financial architecture analysis. Let's design your infrastructure together.
                </p>
                <a href="/en/contact" class="inline-block bg-black text-white px-10 py-4 rounded-xl font-bold hover:shadow-lg hover:-translate-y-1 transition-all relative z-10 font-mono text-sm tracking-widest uppercase">
                    e-TALK
                </a>
            </div>
        </div>
    </section>
    <Footer lang={lang} />
</Layout>

