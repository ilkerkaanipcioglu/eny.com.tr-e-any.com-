---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { 
  Landmark, 
  Rocket, 
  Network, 
  ShieldCheck, 
  History, 
  ArrowRight,
  ArrowDown,
  Cpu,
  School,
  Brain,
  Settings,
  Users,
  Handshake,
  BarChart3,
  Quote,
  LayoutDashboard,
  Search,
  Activity,
  Zap,
  CreditCard,
  Layers,
  Bot
} from '@lucide/astro';

const Acorn = Zap;
const Bird = Layers;
const Fish = Bot;
const Sprout = Zap;
const Leaf = Layers;
const Shell = Bot;
const Waves = Zap;
const Sparkles = Zap;
const lang = 'tr' as const;
---
<Layout title="Hizmetler | eny" lang={lang}>
    <Header lang={lang} />
    <!-- HERO -->
    <header class="relative pt-40 pb-24 md:pt-48 md:pb-32 bg-bg overflow-hidden border-b border-border-main">
        <div class="absolute inset-0 bg-lime opacity-5 blur-[120px] -z-10 rounded-full w-[800px] h-[800px] right-0 top-0 pointer-events-none"></div>

        <div class="max-w-container mx-auto px-8 md:px-12 relative z-10">
            <div class="w-full md:w-3/4 animate-fade-up">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-lime/10 text-lime text-[10px] font-mono tracking-widest uppercase mb-8 border border-lime/20">
                    <Cpu size={14} />
                    FİNANSAL TEKNOLOJİ HİZMETLERİ
                </span>
                
                <h1 class="text-4xl md:text-7xl font-extrabold font-sans mb-6 text-text leading-tight tracking-tighter">
                    Finansal Sistemlerinizi<br/><span class="text-lime">Otomatize Ediyoruz.</span>
                </h1>
                <p class="text-text-70 text-body-lg max-w-2xl w-full font-light leading-relaxed mb-10" style="width: 100%;">
                    Yapay zeka ve modern sistem mimarisiyle finansal operasyonlarınızı sadeleştiriyor, sınır ötesi dönüşüm stratejinizi güvence altına alıyoruz.
                </p>
                
                <div class="flex flex-wrap gap-4">
                    <a href="#hizmetler-grid" class="bg-lime text-black px-8 py-4 rounded-lg font-bold font-mono text-xs uppercase tracking-widest hover:bg-white transition-all inline-flex items-center gap-2">
                        Uzmanlık Alanlarını İncele
                        <ArrowDown size={14} />
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- SERVICES BENTO GRID -->
    <section id="hizmetler-grid" class="py-24 md:py-32 bg-bg2 relative border-b border-border-main">
        <div class="max-w-container mx-auto px-8 md:px-12">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <h2 class="text-3xl md:text-5xl font-extrabold font-sans mb-4 text-text tracking-tighter">Stratejik Odak Alanlarımız</h2>
                    <div class="h-1.5 w-24 bg-lime"></div>
                </div>
                <p class="text-text-70 max-w-md text-sm font-sans font-light leading-relaxed">
                    Yüksek hacimli finansal süreçleri optimize ediyor ve veriye dayalı karar alma algoritmaları kuruyoruz.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[auto]">

                <!-- Kategori 1 Başlığı -->
                <div class="md:col-span-12 mt-4 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-bold font-sans text-lime flex items-center gap-3">
                        <Bird size={28} class="lucide-icon" />
                        1. Kurumsal Platform Çözümleri
                    </h3>
                </div>

<!-- Card 1: Kurumsal Finansal Mimari (Merged) -->
                <div class="md:col-span-8 md:row-span-2 bg-bg3/50 p-10 rounded-2xl flex flex-col justify-between text-text relative overflow-hidden group border border-border-main hover:border-lime transition-all">
                    <div class="absolute right-0 top-0 w-1/2 h-full bg-lime/10 blur-[100px] pointer-events-none opacity-20 transition-opacity group-hover:opacity-40"></div>
                    <div class="relative z-10 w-full">
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-16 h-16 rounded-2xl bg-lime/10 text-lime flex items-center justify-center group-hover:scale-110 transition-transform">
                                <Acorn size={48} class="lucide-icon icon-bounce-hover" />
                            </div>
                            <span class="px-3 py-1 bg-lime/20 text-lime rounded-full text-[10px] font-mono font-bold tracking-[0.1em] uppercase border border-lime/30">Amiral Gemisi</span>
                        </div>
                        <h3 class="text-3xl font-extrabold font-sans mb-3 text-text">Finansal Muhasebe & Maliyet Yönetimi</h3>
                        <p class="text-text-70 text-sm mb-8 font-sans font-light max-w-lg">Kurumsal muhasebe, maliyet kontrolü ve gerçek maliyet hesaplamasını tek bir entegre mimaride sunuyoruz.</p>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-6 text-white/90 text-sm font-light">
                            <div>
                                <p class="text-text font-bold font-mono text-[10px] tracking-widest uppercase mb-3">Genel Muhasebe Yönetimi</p>
                                <ul class="space-y-2 text-text-70">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Defter-i Kebir (New GL)</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Borçlar & Alacaklar (AP/AR)</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Duran Varlık Yönetimi</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Banka Muhasebesi</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Vergi & e-Dönüşüm</li>
                                </ul>
                            </div>
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-3">Maliyet Kontroling</p>
                                <ul class="space-y-2">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Maliyet Merkezi </li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Dahili Sipariş</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Ürün Maliyetlendirme</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Kârlılık Analizi (CO-PA)</li>
                                </ul>
                            </div>
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-3">Stok Değerleme</p>
                                <ul class="space-y-2">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Gerçek Maliyet</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Çoklu Para Birimi Değerleme</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-lime rounded-full"></div>Stok Yeniden Değerleme</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                
<!-- Card 5: ERP Transformation -->
                <div class="md:col-span-4 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-lime transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-6 group-hover:border-lime transition-colors">
                            <Sprout size={24} class="text-text-main group-hover:text-lime transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-bold font-sans mb-3 text-text group-hover:text-lime transition-colors">Dijital ERP Dönüşümü</h3>
                        <p class="text-text-70 text-sm font-sans font-light leading-relaxed mb-6">Greenfield ve Brownfield yaklaşımlarıyla yeni nesil bulut sistemlerine ve modern ERP dünyasına sorunsuz geçiş.</p>
                    </div>
                    <a href="/hakkimizda" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest text-text-main group-hover:text-lime transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                
<!-- Card 6: PS & BPC -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <LayoutDashboard size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Proje & Yatırım Yönetimi</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Yatırım yönetimi, proje planlaması ve bütçe konsolidasyonu süreçlerinizi tek bir merkezde entegre ediyoruz.</p>
                    </div>
                </div>

                
<!-- Card 8: Gayrimenkul Yönetimi -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <Leaf size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Gayrimenkul Portföy Yönetimi</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Ticari gayrimenkul yönetimi, kira kontratları, bakım/onarım ve finansal entegrasyonu ile uçtan uca çözüm.</p>
                    </div>
                    <a href="/iletisim" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                
<!-- Card 12: Likidite Yönetimi -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <Shell size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Nakit ve Likidite Yönetimi</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Nakit görünürlüğünü %100'e çıkarın, banka hesaplarınızı ve likidite tahminlerinizi anlık yönetin.</p>
                    </div>
                    <a href="/e-dbs" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                
<!-- Card 13: Treasury & Risk -->
                <div class="md:col-span-12 md:row-span-1 glass-card p-10 md:p-12 rounded-2xl flex flex-col md:flex-row justify-between items-center group hover:border-lime transition-all duration-300 border-l-4 border-l-transparent hover:border-l-lime">
                    <div class="md:w-2/3 relative z-10">
                        <div class="w-16 h-16 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-8 group-hover:border-lime transition-colors">
                            <Waves size={32} class="text-text-main group-hover:text-lime transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-3xl font-extrabold font-sans mb-4 text-text group-hover:text-lime transition-colors">Hazine ve Risk Yönetimi</h3>
                        <p class="text-text-70 font-sans font-light leading-relaxed md:pr-12">İşletme Sermayesini Optimize Edin, Nakit Verimliliğinde %30 Artış Sağlayın. Finansal veri dokusu üzerinde likidite, ödeme ve risklerinizi tek merkezden yönetin.</p>
                    </div>
                    <div class="md:w-1/3 flex md:justify-end mt-8 md:mt-0 relative z-10">
                        <a href="/hakkimizda" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest bg-bg border border-border-main text-text-main hover:bg-lime hover:text-black hover:border-lime px-8 py-4 rounded-lg transition-all duration-300 whitespace-nowrap">Hemen İncele <ArrowRight size={16} /></a>
                    </div>
                </div>
            
                <!-- Card: Sabit Kıymet -->
                <div class="md:col-span-6 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <Sparkles size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Varlık ve Sabit Kıymet Yönetimi</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Şirketinizin en büyük varlıklarını milimetrik hassasiyetle değerleyin, amortisman planlarınızı otomatikleştirin.</p>
                    </div>
                    <a href="/iletisim" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                <!-- Card: Finansal Konsolidasyon -->
                <div class="md:col-span-6 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <LayoutDashboard size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Finansal Konsolidasyon ve Gruplama</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Holding ve grup şirketinizin kârlılığını tek bakışta gerçek rakamlarla ölçün, süreci aydan güne indirin.</p>
                    </div>
                    <a href="/iletisim" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                <!-- Kategori 2 Başlığı -->
                <div class="md:col-span-12 mt-12 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-bold font-sans text-lime flex items-center gap-3">
                        <Fish size={28} class="lucide-icon" />
                        2. e-Dönüşüm & Dijitalleştirme
                    </h3>
                </div>

<!-- Card 9: Document Automation -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <Search size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">Dijital Arşiv ve Fatura Otomasyonu</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Yapay zeka destekli doküman yönetimi, fatura süreçlerinde tam otomasyon ve sistem entegrasyonu ile dijital dönüşüm.</p>
                    </div>
                    <a href="/iletisim" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                <!-- Card: KDV İade -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <Fish size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">KDV İade Sistemi</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">KDV iade listelerinizi GİB formatına %100 uyumlu şekilde sisteminiz üzerinden tek tıkla oluşturun.</p>
                    </div>
                    <a href="/kdv-iade-paketi" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <ShieldCheck size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">e-Ticaret & Pazaryeri</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Sipariş akışı, stok senkronizasyonu ve pazaryeri hak ediş/komisyon süreçlerini tek merkezden yönetin.</p>
                    </div>
                    <a href="/e-ticaret" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>


                

                <!-- Kategori 3 Başlığı -->
                <div class="md:col-span-12 mt-12 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-bold font-sans text-lime flex items-center gap-3">
                        <Landmark size={28} class="lucide-icon" />
                        3. Finansal Otomasyon & Banka Entegrasyonu
                    </h3>
                </div>

                <!-- Card: E-DBS -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-6 group-hover:border-plum transition-colors">
                            <Landmark size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-bold font-sans mb-3 text-text group-hover:text-plum transition-colors">E-DBS — Doğrudan Borçlandırma</h3>
                        <p class="text-text-70 text-sm font-sans font-light leading-relaxed mb-6">Bayi ve müşteri ağınızdaki tüm DBS işlemlerini tek panelden yönetin, ERP sisteminize tam entegre edin.</p>
                    </div>
                    <a href="/e-dbs" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                <!-- Card: E-Ekstre -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <Bird size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">E-Ekstre & Açık Bankacılık</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Tüm banka hesaplarınızı tek ekrandan yönetin, hesap hareketlerini ERP'nize anında aktarın.</p>
                    </div>
                    <a href="/e-ekstre" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                <!-- Card: E-POS -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-plum transition-colors">
                            <BarChart3 size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-plum transition-colors">E-POS Takip & Raporlama</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Fiziksel ve sanal POS hareketlerinizi tek panelden izleyin, ERP sisteminize otomatik aktarın.</p>
                    </div>
                    <a href="/e-pos" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                <!-- Card: E-Ödeme -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border-main mb-6 group-hover:border-plum transition-colors">
                            <Network size={24} class="text-text-main group-hover:text-plum transition-colors lucide-icon icon-bounce-hover" />
                        </div>
                        <h3 class="text-xl font-bold font-sans mb-3 text-text group-hover:text-plum transition-colors">E-Ödeme Sistemi (TÖS)</h3>
                        <p class="text-text-70 text-sm font-sans font-light leading-relaxed mb-6">Toplu ödeme süreçlerinizi tek merkezden yönetin, tüm bankalara aynı anda talimat gönderin.</p>
                    </div>
                    <a href="/e-payment" class="inline-flex items-center gap-2 font-mono font-bold text-xs uppercase tracking-widest text-text-main group-hover:text-plum transition-colors">Detayları İncele <ArrowRight size={14} /></a>
                </div>

                <!-- Card: E-Nakit Akışı -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-plum transition-all duration-300">
                    <div>
