---
import Layout from '../layouts/Layout.astro';
import IntroAnimation from '../components/IntroAnimation.astro';
---

<Layout title="Yeni Nesil Finansal İşletim Sistemi" lang="tr">
  <!-- 1. HERO ALANI (keny-intro.html içerisindeki Hero Canvas'ımız) -->
  <IntroAnimation lang="tr" />
  
  <section class="max-w-container mx-auto px-6 py-24 relative z-10 animate-fade-up">
    <!-- BÖLÜM 2 — GÜVEN BANDI -->
    <div class="glass-card rounded-2xl p-8 mb-32 relative overflow-hidden group">
       <div class="absolute inset-0 bg-[var(--color-lime)] opacity-0 group-hover:opacity-5 transition-opacity duration-700"></div>
        <div class="flex flex-wrap justify-center sm:justify-between items-center gap-6 font-mono text-[var(--color-lime)] text-xs sm:text-sm relative z-10 text-center sm:text-left">
          <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--color-lime)]"></span> Multi-jurisdiction Compliance</div>
          <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--color-lime)]"></span> 135+ Para Birimi</div>
          <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--color-lime)]"></span> 3 Kıtada Aktif</div>
          <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--color-lime)]"></span> Sovereign Cloud Mimarisi</div>
        </div>
    </div>

    <!-- BÖLÜM 3 — ÜRÜN GRUPLARI -->
    <div class="mb-32">
       <div class="mb-16">
         <span class="font-mono text-[var(--color-lime)] text-xs tracking-widest uppercase mb-4 block">01 / PLATFORM</span>
         <h2 class="text-4xl md:text-5xl font-sans font-extrabold mb-6 max-w-2xl text-[var(--text)] leading-tight">Her Finansal Süreç. <br />Tek Platform.</h2>
         <p class="text-[var(--text-70)] font-sans text-lg max-w-xl">
           Regtech'ten fintech'e, e-ticaretten treasury yönetimine — ihtiyaç duyduğunuz her çözüm eny çatısı altında.
         </p>
       </div>
       
       <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
         <!-- Regtech -->
         <div class="glass-card p-10 rounded-2xl group hover:border-[var(--color-lime)] transition-colors duration-500">
            <span class="font-mono text-[var(--text-40)] text-xs mb-8 block group-hover:text-[var(--color-lime)] transition-colors">REGTECH</span>
             <h3 class="text-2xl font-sans font-bold mb-4">Sovereign e-Dönüşüm</h3>
            <p class="text-[var(--text-70)] text-sm mb-8 leading-relaxed">Ulusal veri gizliliği standartlarına uygun (Sovereign Data Residency), multi-jurisdiction regülasyon kapasitesine sahip e-dönüşüm mimarisi.</p>
            <ul class="text-[var(--text)] text-sm space-y-4 font-sans mb-10">
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> e-Fatura & e-Arşiv (GİB Uyumlu)</li>
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Global Vergi Uyum Motoru</li>
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Yasal Raporlama Otomasyonu</li>
            </ul>
            <a href="/hizmetler/e-donusum" class="text-[var(--color-lime)] font-mono text-sm hover:underline">Detaylı İncele →</a>
         </div>

         <!-- Fintech -->
         <div class="glass-card p-10 rounded-2xl group hover:border-[var(--color-lime)] transition-colors duration-500">
            <span class="font-mono text-[var(--text-40)] text-xs mb-8 block group-hover:text-[var(--color-lime)] transition-colors">FINTECH</span>
            <h3 class="text-2xl font-sans font-bold mb-4">Global Tahsilat Altyapısı</h3>
            <p class="text-[var(--text-70)] text-sm mb-8 leading-relaxed">Vatandaşların veya müşterilerin ödemelerini her kanaldan tahsil eden ulusal ve uluslararası ödeme (Government payment gateway) altyapısı.</p>
            <ul class="text-[var(--text)] text-sm space-y-4 font-sans mb-10">
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Tahsilat Modernizasyonu</li>
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Omni-channel Ödeme (TÖS)</li>
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> B2B & B2G Mutabakat Sistemi</li>
            </ul>
            <a href="/hizmetler/finansal-teknolojiler" class="text-[var(--color-lime)] font-mono text-sm hover:underline">Detaylı İncele →</a>
         </div>

         <!-- E-Commerce -->
         <div class="glass-card p-10 rounded-2xl group hover:border-[var(--color-lime)] transition-colors duration-500">
            <span class="font-mono text-[var(--text-40)] text-xs mb-8 block group-hover:text-[var(--color-lime)] transition-colors">E-TİCARET</span>
            <h3 class="text-2xl font-sans font-bold mb-4">Sınır Tanımaz Ticaret</h3>
            <p class="text-[var(--text-70)] text-sm mb-8 leading-relaxed">Kendi markanızla (White-label, country-branded) tüm dünyaya açılın. Lokal ödeme yöntemleri ve %99 fraud korumasıyla (AI).</p>
            <ul class="text-[var(--text)] text-sm space-y-4 font-sans mb-10">
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> White-Label Checkout</li>
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Cross-Border Payment Routing</li>
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Akıllı Fraud Koruması</li>
            </ul>
            <a href="/hizmetler/e-ticaret" class="text-[var(--color-lime)] font-mono text-sm hover:underline">Detaylı İncele →</a>
         </div>

         <!-- Treasury -->
         <div class="glass-card p-10 rounded-2xl group hover:border-[var(--color-lime)] transition-colors duration-500">
            <span class="font-mono text-[var(--text-40)] text-xs mb-8 block group-hover:text-[var(--color-lime)] transition-colors">TREASURY</span>
            <h3 class="text-2xl font-sans font-bold mb-4">Treasury & Financial Inclusion</h3>
            <p class="text-[var(--text-70)] text-sm mb-8 leading-relaxed">Ulusal veya kurumsal ölçekte hazine operasyonlarını yönetin. Interoperable sistemler ile %98 doğrulukla finansal kontrol.</p>
            <ul class="text-[var(--text)] text-sm space-y-4 font-sans mb-10">
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Nakit Projeksiyonu & Analitik</li>
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Interoperable Ödeme Yönetimi</li>
              <li class="flex items-center gap-3"><span class="text-[var(--color-lime)] font-mono">→</span> Gerçek Zamanlı Risk Analizi</li>
            </ul>
            <a href="#treasury" class="text-[var(--color-lime)] font-mono text-sm hover:underline">Detaylı İncele →</a>
         </div>
       </div>
    </div>

    <!-- BÖLÜM 4 — PROVEN AT SCALE (GLOBAL INFRASTRUCTURE) -->
    <div class="mb-32">
       <div class="mb-16 text-center lg:text-left flex flex-col lg:flex-row justify-between items-end gap-6">
         <div>
           <span class="font-mono text-[var(--color-lime)] text-xs tracking-widest uppercase mb-4 block">02 / PROVEN AT SCALE</span>
           <h2 class="text-4xl md:text-5xl font-sans font-extrabold text-[var(--text)] leading-tight max-w-2xl">Milyonlarca Vatandaş.<br/>Milyarlarca İşlem.</h2>
         </div>
       </div>

       <div class="glass-card rounded-2xl p-10 md:p-16 relative overflow-hidden group hover:border-[var(--color-lime)] transition-colors duration-500">
         <div class="absolute right-0 top-0 w-64 h-64 bg-[var(--color-lime)] blur-[150px] opacity-10 pointer-events-none group-hover:opacity-20 transition-opacity"></div>
         <div class="flex flex-col lg:flex-row items-center gap-12 relative z-10">
           <div class="flex-1">
             <h3 class="text-3xl md:text-4xl font-sans font-bold mb-6 text-[var(--text)]">Bir Metropolün Tahsilatını<br/>Baştan Tasarladık.</h3>
             <p class="text-[var(--text-70)] text-lg leading-relaxed mb-6">
               <span class="text-[var(--color-lime)] font-bold">4.2 milyon</span> vatandaşın su ve vergi ödemelerini uçtan uca sayısallaştırarak, tahsilat oranlarında <span class="text-[var(--color-lime)] font-bold">18 ay içerisinde %340 büyüme</span> sağladık. 
             </p>
             <p class="text-[var(--text-70)] text-sm leading-relaxed max-w-xl">
               Uluslararası standartlarda (Digital public infrastructure), donor-funding projelerine uyumlu yapısıyla gelişmekte olan tüm bölgeler ve kurumsal pazar liderleri için optimize edilmiş TCO.
             </p>
           </div>
           <div class="w-full lg:w-auto flex flex-col gap-8 font-mono bg-black/20 p-8 rounded-xl border border-white/5">
              <div class="border-l-2 border-[var(--color-lime)] pl-6">
                <div class="text-4xl font-bold text-[var(--color-lime)] mb-2">%340</div>
                <div class="text-sm text-[var(--text-70)]">Tahsilat Artışı</div>
              </div>
              <div class="border-l-2 border-[var(--color-lime)] pl-6">
                <div class="text-4xl font-bold text-[var(--color-lime)] mb-2">4.2M</div>
                <div class="text-sm text-[var(--text-70)]">Aktif Kullanıcı</div>
              </div>
              <div class="border-l-2 border-[var(--color-lime)] pl-6">
                <div class="text-4xl font-bold text-[var(--color-lime)] mb-2">~100ms</div>
                <div class="text-sm text-[var(--text-70)]">İşlem Hızı</div>
              </div>
           </div>
         </div>
       </div>
    </div>

    <!-- BÖLÜM 5 — TEKNOLOJİ & YAPI -->
    <div class="mb-32">
       <div class="mb-16">
         <span class="font-mono text-[var(--color-lime)] text-xs tracking-widest uppercase mb-4 block">03 / TEKNOLOJİ & YAPI</span>
         <h2 class="text-4xl md:text-5xl font-sans font-extrabold mb-6 max-w-2xl text-[var(--text)] leading-tight">Finansın<br/>Yeni Mimarisi.</h2>
         <p class="text-[var(--text-70)] font-sans text-lg max-w-xl">
           Sisteminizi kurarken sadece bugünün değil, yarının da global standartlarını ve regülasyonlarını merkeze alıyoruz. Tamamen API-first, tamamen güvenli.
         </p>
       </div>
       
       <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Item 1 -->
          <div class="border border-[var(--border)] p-10 rounded-xl relative overflow-hidden group hover:border-[var(--color-lime)] transition-colors duration-500 bg-[var(--surface)]/30 backdrop-blur-sm">
            <div class="text-4xl mb-6 opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all">🔒</div>
            <h4 class="text-xl font-bold mb-4 font-sans text-[var(--text)] group-hover:text-[var(--color-lime)] transition-colors">Zero-Trust Security</h4>
            <p class="text-sm text-[var(--text-70)] leading-relaxed">
              Verileriniz sadece şifrelenmez; uluslararası standartlarda parçalanarak soyutlanır. Yüksek ölçekli finans kurumlarında (DPI) kullanılan askeri düzeyde koruma ve veri bütünlüğü onayları.
            </p>
          </div>
          <!-- Item 2 -->
          <div class="border border-[var(--border)] p-10 rounded-xl relative overflow-hidden group hover:border-[var(--color-lime)] transition-colors duration-500 bg-[var(--surface)]/30 backdrop-blur-sm">
            <div class="text-4xl mb-6 opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all">⚡</div>
            <h4 class="text-xl font-bold mb-4 font-sans text-[var(--text)] group-hover:text-[var(--color-lime)] transition-colors">API-First Architecture</h4>
            <p class="text-sm text-[var(--text-70)] leading-relaxed">
              Kapsamlı dokümantasyona sahip, esnek ve anlık yanıt veren REST/GraphQL yapısı. SAP, Oracle veya kendi geliştirdiğiniz özel yazılımlar ile saatler içinde native konuşabilen teknoloji.
            </p>
          </div>
          <!-- Item 3 -->
          <div class="border border-[var(--border)] p-10 rounded-xl relative overflow-hidden group hover:border-[var(--color-lime)] transition-colors duration-500 bg-[var(--surface)]/30 backdrop-blur-sm">
            <div class="text-4xl mb-6 opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all">🌐</div>
            <h4 class="text-xl font-bold mb-4 font-sans text-[var(--text)] group-hover:text-[var(--color-lime)] transition-colors">Cross-Border Uyumu</h4>
            <p class="text-sm text-[var(--text-70)] leading-relaxed">
              Farklı ülkelerin yasal regülasyonlarına (Multi-jurisdictional compliance) otomatik adapte olan, sınır ötesi ticareti şirketiniz için yerelmiş gibi gösteren altyapı.
            </p>
          </div>
       </div>
    </div>
  </section>
</Layout>
