---
export interface Props {
  title: string;
  lang?: 'tr' | 'en';
  description?: string;
  image?: string;
}

import '../styles/global.css';

const { 
  title, 
  lang = 'tr',
  description = lang === 'tr' 
    ? 'eny - Finansın Yeni İşletim Sistemi. e-Dönüşüm, Finansal Teknolojiler ve e-Ticaret.'
    : 'eny - The New Operating System of Finance. e-Transformation, Financial Technologies, and e-Commerce.',
  image = '/images/logo/eny.svg'
} = Astro.props;

// Default URL for eny.com.tr
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://eny.com.tr');
---

<!DOCTYPE html>
<html class="scroll-smooth" lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | eny</title>
    <meta name="description" content={description} />
    
    <!-- SEO / Canonical -->
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={`${title} | eny`} />
    <meta property="og:description" content={description} />

    <!-- Theme: track OS preference dynamically -->
    <script is:inline>
      (function() {
        const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
        
        function applyTheme() {
          const stored = localStorage.getItem('eny-theme');
          // Enforce dark theme as default if no preference is stored
          const preferred = mediaQuery.matches ? 'dark' : 'dark'; 
          document.documentElement.setAttribute('data-theme', stored || preferred);
        }
        
        applyTheme();

        // If user changes Windows setting, apply it
        mediaQuery.addEventListener('change', (e) => {
          if(!localStorage.getItem('eny-theme')) {
            document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
          }
        });
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  </head>
  <body class="selection:bg-lime selection:text-[#050806]">
    <div id="app">
        <slot />
    </div>
  </body>
</html>

<style is:global>
  /* === SCROLLBAR === */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-40); }

  /* === BASE UTILITIES === */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--border) 50%, transparent 100%);
  }

  html { scroll-behavior: smooth; }
  
  /* Animations */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
</style>
