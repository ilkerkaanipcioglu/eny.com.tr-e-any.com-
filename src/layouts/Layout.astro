---
export interface Props {
  title: string;
  lang?: 'tr' | 'en';
  description?: string;
  image?: string;
}

import '../styles/global.css';

const { 
  title, 
  lang = 'tr',
  description = lang === 'tr' 
    ? 'eny - Finansın Yeni İşletim Sistemi. e-Dönüşüm, Finansal Teknolojiler ve e-Ticaret.'
    : 'eny - The New Operating System of Finance. e-Transformation, Financial Technologies, and e-Commerce.',
  image = '/images/logo/eny_full_dark.png'
} = Astro.props;

// Default URL for eny.com.tr
const canonicalURL = new URL(Astro.url.pathname, 'https://eny.com.tr');
---

<!DOCTYPE html>
<html class="scroll-smooth" lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | eny</title>
    <meta name="description" content={description} />
    
    <!-- SEO / Canonical / Hreflang (Independent Domains) -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang="tr" href="https://eny.com.tr/" />
    <link rel="alternate" hreflang="en" href="https://eny.com.tr/en/" />
    <link rel="alternate" hreflang="x-default" href="https://eny.com.tr/" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={`${title} | eny`} />
    <meta property="og:description" content={description} />

    <!-- Geo-IP & Language Preference (Domain Specific) -->
    <script is:inline>
      (function() {
        const pref = localStorage.getItem('eny-lang-pref');
        const geoChecked = sessionStorage.getItem('eny-geo-checked');
        const currentPath = window.location.pathname;
        const currentHost = window.location.hostname;
        const isEnPath = currentPath.startsWith('/en');
        const isEnDomain = currentHost === 'e-any.com' || currentHost === 'www.e-any.com';

        // 1. Domain-based override for e-any.com (English Portal)
        if (isEnDomain && !isEnPath && currentPath === '/') {
          window.location.href = '/en/';
          return;
        }

        // 2. Local Preference Sync (Stay on same domain)
        if (pref) {
          if (pref === 'en' && !isEnPath && currentPath === '/') {
            window.location.href = '/en/';
            return;
          } else if (pref === 'tr' && isEnPath) {
            // Optional: User has explicit TR preference but is on EN path
            // Usually we let them stay where they are unless it's the root
          }
        }

        // 3. Simple Geo-IP (Optional, unified domain)
        if (!geoChecked && (currentPath === '/' || currentPath === '/en' || currentPath === '/en/')) {
          fetch('https://ipapi.co/json/')
            .then(res => res.json())
            .then(data => {
              sessionStorage.setItem('eny-geo-checked', 'true');
              if (data.country_code && data.country_code !== 'TR') {
                if (!isEnPath) {
                   localStorage.setItem('eny-lang-pref', 'en');
                   window.location.href = '/en/';
                }
              }
            })
            .catch(err => {
              sessionStorage.setItem('eny-geo-checked', 'true');
            });
        }
      })();
    </script>

    <!-- Theme: track OS preference dynamically -->
    <script is:inline>
      (function() {
        function applyTheme() {
          const stored = localStorage.getItem('eny-theme');
          if (stored) {
            document.documentElement.setAttribute('data-theme', stored);
            return;
          }
          // Default to dark if no preference
          document.documentElement.setAttribute('data-theme', 'dark');
        }
        
        applyTheme();

        // Listen for OS changes only if no manual preference stored
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
          if(!localStorage.getItem('eny-theme')) {
            document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
          }
        });
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">

  </head>
  <body class="selection:bg-lime selection:text-[#050806]">
    <div id="app">
        <slot />
    </div>
  </body>
</html>

<style is:global>
  /* === SCROLLBAR === */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-40); }

  /* === BASE UTILITIES === */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--border) 50%, transparent 100%);
  }

  html { scroll-behavior: smooth; }
  
  /* Animations */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
</style>
