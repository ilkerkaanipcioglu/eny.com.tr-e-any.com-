---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  name: string;
  size?: number | string;
  class?: string;
  animate?: boolean;
  brand?: 'lesstupid' | 'eny';
  variant?: 'nav' | 'illu';
}

const { 
  name, 
  size = 24, 
  class: className = '', 
  animate = false,
  brand = 'eny', // Default for eny.com.tr
  variant 
} = Astro.props;

// 1. Determine Matrix Variant
const numericSize = typeof size === 'string' ? parseInt(size) : size;
const selectedVariant = variant || (numericSize > 48 ? 'illu' : 'nav');

// 2. Resolve Path
let finalPath = '';
const isSystemIcon = name.startsWith('icon_');

if (isSystemIcon) {
  const brandSuffix = brand === 'lesstupid' ? 'l' : 'e';
  const variantSuffix = selectedVariant;
  
  // Cascading fallback: brand+variant → variant only → base icon
  const candidates = [
    `${name}_${brandSuffix}_${variantSuffix}.svg`,
    `${name}_${variantSuffix}.svg`,
    `${name}.svg`,
  ];
  
  const iconsDir = path.join(process.cwd(), 'public', 'icons');
  finalPath = '';
  for (const candidate of candidates) {
    const candidatePath = path.join(iconsDir, candidate);
    if (fs.existsSync(candidatePath)) {
      finalPath = candidatePath;
      break;
    }
  }
  if (!finalPath) {
    finalPath = path.join(iconsDir, candidates[0]);
  }
} else {
  finalPath = path.join(process.cwd(), 'public', 'icons', `${name}.svg`);
}

let svgContent = '';
let viewBox = '0 0 500 500';

try {
  if (fs.existsSync(finalPath)) {
    const content = fs.readFileSync(finalPath, 'utf-8');
    
    const viewBoxMatch = content.match(/viewBox="([^"]+)"/);
    if (viewBoxMatch) {
      viewBox = viewBoxMatch[1];
    }

    svgContent = content
      .replace(/<svg[^>]*>/, '') 
      .replace(/<\/svg>/, '')    
      .replace(/width="[^"]*"/g, '') 
      .replace(/height="[^"]*"/g, '')
      // Remove background fills (common white/off-white values used in the vectorizer)
      .replace(/fill="#f8f8f8"/gi, 'fill="none"')
      .replace(/fill="#ffffff"/gi, 'fill="none"')
      .replace(/stroke="#f8f8f8"/gi, 'stroke="none"')
      .replace(/stroke="#ffffff"/gi, 'stroke="none"');

  } else {
    // Silent fallback to avoid crashing build, but warn in dev
    if (process.env.NODE_ENV !== 'production') {
        console.warn(`⚠️ Icon not found: ${finalPath}`);
    }
  }
} catch (err) {
  console.error(`❌ Error reading icon: ${finalPath}`, err);
}
---

<div 
  class={`icon-container ${animate ? 'animate-wobble' : ''} ${className}`}
  style={`width: ${numericSize}px; height: ${numericSize}px;`}
>
  <svg 
    viewBox={viewBox} 
    fill="none" 
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-full"
    style={isSystemIcon ? "transform: scale(1.0);" : "transform: scale(1.6);"}
    set:html={svgContent}
  />
</div>

<style>
  .icon-container {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
    transition: transform 0.3s ease;
  }

  /* Signature Wobble Animation */
  .animate-wobble:hover {
    animation: wobble 0.5s ease-in-out infinite alternate;
  }

  @keyframes wobble {
    0% { transform: rotate(-2deg) scale(1); }
    100% { transform: rotate(2deg) scale(1.05); }
  }
</style>
