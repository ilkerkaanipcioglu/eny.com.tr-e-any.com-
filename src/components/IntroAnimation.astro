---
import { t, type Lang } from '../i18n/utils';

export interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

interface WordMap {
  w: string;
  l: string;
}

const trWords: WordMap[] = [
  { w: 'e-fatura', l: '/urunler' },
  { w: 'e-dönüşüm', l: '/hizmetler' },
  { w: 'e-arşiv', l: '/urunler' },
  { w: 'e-defter', l: '/urunler' },
  { w: 'e-imza', l: '/urunler' },
  { w: 'e-irsaliye', l: '/urunler' },
  { w: 'e-ödeme', l: '/e-payment' },
  { w: 'e-tahsilat', l: '/e-tahsilat' },
  { w: 'e-dbs', l: '/e-dbs' },
  { w: 'e-ekstre', l: '/e-ekstre' },
  { w: 'e-ticaret', l: '/e-ticaret' },
  { w: 'e-devlet', l: '/urunler' },
  { w: 'e-mutabakat', l: '/urunler' },
  { w: 'e-sözleşme', l: '/urunler' },
  { w: 'e-bordro', l: '/urunler' },
  { w: 'e-teklif', l: '/urunler' },
  { w: 'e-satın alma', l: '/e-ticaret' },
  { w: 'e-sipariş', l: '/e-ticaret' },
  { w: 'e-stok', l: '/urunler' },
  { w: 'e-masraf', l: '/urunler' },
  { w: 'e-bütçe', l: '/hizmetler' },
  { w: 'e-kasa', l: '/hizmetler' },
  { w: 'e-denetim', l: '/urunler' },
  { w: 'e-risk', l: '/teknoloji' },
  { w: 'e-scoring', l: '/teknoloji' },
  { w: 'e-kyc', l: '/teknoloji' },
  { w: 'e-onboarding', l: '/teknoloji' },
  { w: 'e-abonelik', l: '/e-tahsilat' },
  { w: 'e-sadakat', l: '/urunler' },
  { w: 'e-wallet', l: '/e-payment' },
  { w: 'e-treasury', l: '/hizmetler' },
  { w: 'e-tös', l: '/e-payment' },
  { w: 'e-nakit akışı', l: '/e-cashflow' },
  { w: 'e-any', l: '/' },
  { w: 'eny.com.tr', l: '/' },
  { w: 'ENY', l: '/' },
];

const enWords: WordMap[] = [
  { w: 'e-invoice', l: '/en/products' },
  { w: 'e-transformation', l: '/en/services' },
  { w: 'e-archive', l: '/en/products' },
  { w: 'e-ledger', l: '/en/products' },
  { w: 'e-signature', l: '/en/products' },
  { w: 'e-waybill', l: '/en/products' },
  { w: 'e-payment', l: '/en/e-payment' },
  { w: 'e-collection', l: '/en/e-collection' },
  { w: 'e-dbs', l: '/en/e-dbs' },
  { w: 'e-dds', l: '/en/e-dbs' },
  { w: 'e-statement', l: '/en/e-statement' },
  { w: 'e-commerce', l: '/en/e-commerce' },
  { w: 'e-government', l: '/en/products' },
  { w: 'e-reconciliation', l: '/en/products' },
  { w: 'e-contract', l: '/en/products' },
  { w: 'e-procurement', l: '/en/e-commerce' },
  { w: 'e-order', l: '/en/e-commerce' },
  { w: 'e-audit', l: '/en/products' },
  { w: 'e-risk', l: '/en/technology' },
  { w: 'e-scoring', l: '/en/technology' },
  { w: 'e-kyc', l: '/en/technology' },
  { w: 'e-onboarding', l: '/en/technology' },
  { w: 'e-subscription', l: '/en/e-collection' },
  { w: 'e-loyalty', l: '/en/products' },
  { w: 'e-wallet', l: '/en/e-payment' },
  { w: 'e-treasury', l: '/en/services' },
  { w: 'e-cashflow', l: '/en/e-cashflow' },
  { w: 'e-rollout', l: '/en/rollout' },
  { w: 'e-any', l: '/en/' },
  { w: 'eny.com.tr', l: '/en/' },
  { w: 'ENY', l: '/en/' },
];

const words = lang === 'tr' ? trWords : enWords;
const wordsJson = JSON.stringify(words);
const introStatus = t('introStatus', lang);
---

<div id="intro-stage" data-lang={lang} data-words={wordsJson}>
  <canvas id="intro-bg"></canvas>
  <div class="neon-radial-glow top-left"></div>
  <div class="neon-radial-glow bottom-right"></div>
  <div id="grid-overlay"></div>
  <div id="vignette"></div>
  <div id="scan"></div>
  <div id="glitch-overlay"></div>

  <div class="corner" id="c-tl"></div>
  <div class="corner" id="c-tr"></div>
  <div class="corner" id="c-bl"></div>
  <div class="corner" id="c-br"></div>

  <div id="intro-content">
    <div id="stream-area"></div>
    <div id="logo-block">
      <div id="logo-glow"></div>
      <div id="logo-image-container">
        <div class="intro-logo-row flex items-center justify-center">
          <div class="intro-icon-wrapper relative">
            <img src="/images/logo/eny_icon.png" alt="eny" class="intro-logo-icon h-32 md:h-40 w-auto object-contain hidden-in-light" />
            <img src="/images/logo/eny_icon_black.png" alt="eny" class="intro-logo-icon h-32 md:h-40 w-auto object-contain hidden-in-dark" />
          </div>
          <div class="intro-text-wrapper">
            <span class="intro-wordmark text-[100px] md:text-[140px] font-extrabold tracking-tighter text-white" style="font-family: var(--font-sans)">eny<span class="intro-dot">.</span></span>
          </div>
        </div>
      </div>
      <div id="logo-domain">ENY.COM.TR</div>
    </div>
  </div>
</div>

<style>
  #intro-stage {
    width: 100%;
    height: 100vh;
    min-height: 700px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: transparent;
  }

  canvas#intro-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #glitch-overlay {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    mix-blend-mode: screen;
  }

  #vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  :global([data-theme="dark"]) #vignette {
    background: radial-gradient(ellipse at center, transparent 20%, rgba(4,6,5,0.95) 100%);
  }
  :global([data-theme="light"]) #vignette {
    background: radial-gradient(ellipse at center, transparent 20%, rgba(240,245,236,0.75) 100%);
  }

  .neon-radial-glow {
    position: absolute;
    width: 60vw;
    height: 60vw;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(circle, var(--lime-glow) 0%, transparent 70%);
    transition: opacity 1.2s ease;
  }
  .neon-radial-glow.on { opacity: 0.14; }
  .top-left { top: -20%; left: -20%; }
  .bottom-right { bottom: -20%; right: -20%; }

  #grid-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }
  :global([data-theme="dark"]) #grid-overlay {
    background-image:
      linear-gradient(rgba(208,253,23,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(208,253,23,0.04) 1px, transparent 1px);
    background-size: 52px 52px;
  }
  :global([data-theme="light"]) #grid-overlay {
    background-image:
      linear-gradient(rgba(80,140,50,0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(80,140,50,0.07) 1px, transparent 1px);
    background-size: 52px 52px;
  }
  #grid-overlay.on { opacity: 1; }

  #scan {
    position: absolute;
    left: 0; right: 0;
    height: 2px;
    z-index: 2;
    top: 0;
    pointer-events: none;
    opacity: 0;
    filter: blur(0.5px);
  }
  :global([data-theme="dark"]) #scan {
    background: linear-gradient(90deg, transparent 0%, rgba(208,253,23,0.0) 10%, rgba(208,253,23,0.8) 50%, rgba(208,253,23,0.0) 90%, transparent 100%);
    box-shadow: 0 0 12px rgba(208,253,23,0.5);
  }
  :global([data-theme="light"]) #scan {
    background: linear-gradient(90deg, transparent 0%, rgba(60,140,30,0.0) 10%, rgba(60,140,30,0.6) 50%, rgba(60,140,30,0.0) 90%, transparent 100%);
    box-shadow: 0 0 8px rgba(60,140,30,0.4);
  }

  #intro-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  #stream-area {
    width: 100%;
    max-width: 720px;
    min-height: 160px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px 14px;
    padding: 0 40px;
    margin-bottom: 52px;
  }

  :global(.sw) {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    color: var(--word-base);
    letter-spacing: 0.04em;
    opacity: 0;
    transform: translateY(6px) scale(0.95);
    transition: opacity 0.25s cubic-bezier(0.22,1,0.36,1),
                transform 0.25s cubic-bezier(0.22,1,0.36,1),
                color 0.2s,
                text-shadow 0.2s;
    white-space: nowrap;
    text-decoration: none;
    pointer-events: none;
  }
  :global(.sw.on) {
    opacity: 1;
    transform: translateY(0) scale(1);
    color: var(--word-on);
    pointer-events: auto;
  }
  :global(.sw.on:hover) {
    color: var(--lime);
    transform: translateY(-2px) scale(1.06);
  }
  :global(.sw.glow) {
    color: var(--word-glow);
    text-shadow: 0 0 12px var(--lime-glow), 0 0 28px var(--lime-soft);
  }
  :global([data-theme="light"] .sw.glow) {
    text-shadow: 0 0 8px rgba(42,96,24,0.5);
  }
  :global(.sw.dim) {
    opacity: 0.55;
    color: var(--word-on);
    text-shadow: none;
  }
  :global(.sw.highlight) {
    font-weight: 600;
    font-size: 13px;
  }
  :global(.sw.burst) {
    animation: sw-burst 0.35s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  @keyframes sw-burst {
    0%   { opacity: 0; transform: translateY(10px) scale(0.8); }
    60%  { opacity: 1; transform: translateY(-2px) scale(1.08); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  #logo-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    opacity: 0;
    transform: translateY(16px) scale(0.92);
    transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1),
                transform 0.7s cubic-bezier(0.22,1,0.36,1);
    position: relative;
  }
  #logo-block.show {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  #logo-block.glitch {
    animation: logo-glitch 0.4s steps(2) forwards;
  }
  @keyframes logo-glitch {
    0%   { clip-path: inset(0 0 85% 0); transform: translate(-3px, 0) scale(1); }
    20%  { clip-path: inset(40% 0 30% 0); transform: translate(3px, 0) scale(1); }
    40%  { clip-path: inset(70% 0 10% 0); transform: translate(-2px, 0) scale(1); }
    60%  { clip-path: none; transform: translate(0) scale(1.01); }
    80%  { clip-path: inset(10% 0 80% 0); transform: translate(2px, 0) scale(1); }
    100% { clip-path: none; transform: translate(0) scale(1); }
  }

  #logo-glow {
    position: absolute;
    width: 320px;
    height: 320px;
    background: var(--lime-glow);
    filter: blur(100px);
    opacity: 0;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: -1;
    transition: opacity 1s ease;
  }
  #logo-glow.show { opacity: 0.1; }
  :global([data-theme="light"]) #logo-glow.show { opacity: 0.05; background: #3a7a20; }

  #logo-image-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .intro-logo-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .intro-logo-row {
      flex-direction: row;
      gap: clamp(0.5rem, 2vw, 1.5rem);
    }
  }

  .intro-logo-icon {
    height: clamp(100px, 20vw, 260px);
    width: auto;
    object-fit: contain;
    animation: icon-glow-pulse 2.5s infinite alternate cubic-bezier(0.4, 0, 0.6, 1);
  }

  .intro-wordmark {
    font-size: clamp(80px, 15vw, 180px);
    line-height: 1;
    letter-spacing: -0.06em;
    font-family: var(--font-sans);
    font-weight: 800;
    white-space: nowrap;
    color: #FFFFFF;
    text-shadow: none !important;
  }

  .intro-dot {
    display: inline-block;
    color: var(--lime);
  }

  @keyframes icon-glow-pulse {
    0% { filter: drop-shadow(0 0 5px rgba(208,253,23,0.1)); opacity: 0.88; }
    100% { filter: drop-shadow(0 0 40px rgba(208,253,23,0.65)); opacity: 1; }
  }

  #logo-domain {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--domain-color);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.6s, transform 0.6s;
    margin-top: -10px;
  }
  #logo-domain.show {
    opacity: 0.85;
    transform: translateY(0);
  }

  .corner {
    position: absolute;
    width: 20px; height: 20px;
    opacity: 0;
    z-index: 3;
    transition: opacity 0.4s, border-color 0.4s;
    border-color: var(--corner);
    border-style: solid;
  }
  #c-tl { top: 22px; left: 22px; border-width: 1px 0 0 1px; }
  #c-tr { top: 22px; right: 22px; border-width: 1px 1px 0 0; }
  #c-bl { bottom: 22px; left: 22px; border-width: 0 0 1px 1px; }
  #c-br { bottom: 22px; right: 22px; border-width: 0 1px 1px 0; }
  .corner.show { opacity: 1; }

  #status-bar {
    position: absolute;
    bottom: 22px; left: 40px;
    z-index: 10;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--word-on);
    letter-spacing: 0.06em;
    opacity: 0;
    transition: opacity 0.4s, color 0.4s;
  }
  #status-bar.show { opacity: 1; }

  @media (max-width: 480px) {
    #stream-area { gap: 6px 10px; padding: 0 24px; }
    :global(.sw) { font-size: 11px; }
    #status-bar { left: 22px; }
  }
</style>

<script>
  function initIntroAnimation() {
    const stage = document.getElementById('intro-stage');
    if (!stage) return;

    const lang = stage.getAttribute('data-lang') || 'tr';
    const WORDS = JSON.parse(stage.getAttribute('data-words') || '[]');

    const canvas = document.getElementById('intro-bg') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    let W: number, H: number;
    let particles: any[] = [];
    let rafId: number;
    let tids: ReturnType<typeof setTimeout>[] = [];
    let mouseX = 0, mouseY = 0;

    const getTheme = () => document.documentElement.getAttribute('data-theme') || 'dark';

    window.addEventListener('mousemove', e => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    }, { passive: true });

    function resize() {
      const rect = stage.getBoundingClientRect();
      W = canvas.width = rect.width;
      H = canvas.height = rect.height;
    }

    function mkParticle() {
      const lime = Math.random() < 0.18;
      return {
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.32,
        vy: (Math.random() - 0.5) * 0.32,
        r: Math.random() * 1.6 + 0.3,
        a: Math.random() * 0.55 + 0.1,
        lime,
        pulse: Math.random() * Math.PI * 2,
        speed: 0.018 + Math.random() * 0.012,
      };
    }

    function initParticles() {
      particles = [];
      const count = Math.min(150, Math.floor(W * H / 8500));
      for (let i = 0; i < count; i++) particles.push(mkParticle());
    }

    let lastFrame = 0;
    function drawBg(ts = 0) {
      if (!ctx) return;
      const dt = Math.min((ts - lastFrame) / 16.67, 3);
      lastFrame = ts;

      ctx.clearRect(0, 0, W, H);
      const dark = getTheme() === 'dark';
      const cx = mouseX || W / 2;
      const cy = mouseY || H / 2;

      const limeC   = (a: number) => dark ? `rgba(208,253,23,${a})`    : `rgba(60,130,30,${a})`;
      const neutralC = (a: number) => dark ? `rgba(60,90,65,${a})`     : `rgba(120,170,90,${a})`;
      const lineC   = (a: number) => dark ? `rgba(42,61,46,${a})`      : `rgba(120,170,90,${a})`;

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        const dx = (cx - p.x) * 0.00006;
        const dy = (cy - p.y) * 0.00006;
        p.vx += dx * dt; p.vy += dy * dt;
        const spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (spd > 0.5) { p.vx *= 0.5 / spd; p.vy *= 0.5 / spd; }
        p.x += p.vx * dt; p.y += p.vy * dt;
        p.pulse += p.speed * dt;
        if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
        const pulse = 0.75 + Math.sin(p.pulse) * 0.25;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * pulse, 0, Math.PI * 2);
        ctx.fillStyle = p.lime
          ? limeC(p.a * pulse * (dark ? 1 : 0.65))
          : neutralC(p.a * 0.55 * pulse * (dark ? 1 : 0.7));
        ctx.fill();
      }

      const MAX_DIST = 100;
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const d2 = dx * dx + dy * dy;
          if (d2 < MAX_DIST * MAX_DIST) {
            const alpha = (1 - Math.sqrt(d2) / MAX_DIST) * (dark ? 0.45 : 0.32);
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = lineC(alpha);
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
      rafId = requestAnimationFrame(drawBg);
    }

    function clearTids() { tids.forEach(clearTimeout); tids = []; }

    function tid(fn: () => void, ms: number) {
      const id = setTimeout(fn, ms);
      tids.push(id);
      return id;
    }

    function triggerGlitch() {
      const overlay = document.getElementById('glitch-overlay');
      if (!overlay) return;
      const dark = getTheme() === 'dark';
      const frames = [
        { bg: dark ? 'rgba(208,253,23,0.06)' : 'rgba(60,130,30,0.04)', clip: 'inset(15% 0 70% 0)' },
        { bg: dark ? 'rgba(208,253,23,0.04)' : 'rgba(60,130,30,0.03)', clip: 'inset(60% 0 20% 0)' },
        { bg: 'transparent', clip: 'none' },
      ];
      let fi = 0;
      const next = () => {
        if (fi >= frames.length) { overlay.style.opacity = '0'; return; }
        overlay.style.opacity = '1';
        overlay.style.background = frames[fi].bg;
        overlay.style.clipPath = frames[fi].clip;
        fi++;
        setTimeout(next, 60);
      };
      next();
    }

    function startIntro() {
      clearTids();
      cancelAnimationFrame(rafId);

      const area = document.getElementById('stream-area');
      if (!area) return;
      area.innerHTML = '';
      const els: HTMLAnchorElement[] = [];

      const skipIntro = (e?: Event) => {
        if (e && e.target instanceof HTMLAnchorElement && e.target.href) {
           // allow natural navigation if clicking a link during animation
           return;
        }
        clearTids();
        els.forEach(el => {
          el.classList.remove('glow', 'burst');
          el.classList.add('dim', 'on');
        });
        showLogo(true);
      };

      const onScroll = () => {
        if (window.scrollY > 20) { skipIntro(); window.removeEventListener('scroll', onScroll); }
      };
      window.addEventListener('scroll', onScroll);

      WORDS.forEach((itemObj: { w: string, l: string }, i: number) => {
        const el = document.createElement('a');
        el.href = itemObj.l;
        el.className = 'sw' + (i >= WORDS.length - 3 ? ' highlight' : '');
        el.textContent = itemObj.w;
        area.appendChild(el);
        els.push(el);
      });

      const lb         = document.getElementById('logo-block');
      const lg         = document.getElementById('logo-glow');
      const nrgs       = document.querySelectorAll('.neon-radial-glow');
      const logoDomain = document.getElementById('logo-domain');
      const corners    = ['c-tl','c-tr','c-bl','c-br'].map(id => document.getElementById(id));
      const grid       = document.getElementById('grid-overlay');

      [lb, lg, grid, logoDomain].forEach(el => {
        el?.classList.remove('show', 'on', 'glitch');
      });
      nrgs.forEach(n => n.classList.remove('on'));
      corners.forEach(c => c?.classList.add('show'));

      initParticles();
      rafId = requestAnimationFrame(drawBg);

      const scan = document.getElementById('scan');
      if (scan) {
        let scanPos = -2;
        scan.style.opacity = '1';
        scan.style.top = '0px';
        const scanRaf = () => {
          scanPos += 4;
          scan.style.top = scanPos + 'px';
          if (scanPos < H) requestAnimationFrame(scanRaf);
          else { scan.style.opacity = '0'; }
        };
        tid(() => { grid?.classList.add('on'); requestAnimationFrame(scanRaf); }, 80);
      }

      const BATCH = 3;
      const WORD_INTERVAL = 28;
      let wordsDone = 0;

      const streamBatch = () => {
        const end = Math.min(wordsDone + BATCH, els.length);
        for (let i = wordsDone; i < end; i++) {
          const el = els[i];
          el.classList.add('on');
          setTimeout(() => {
            el.classList.add('glow');
            setTimeout(() => { el.classList.remove('glow'); el.classList.add('dim'); }, 200);
          }, 20);
        }
        wordsDone = end;
        if (wordsDone < els.length) {
          tid(streamBatch, WORD_INTERVAL);
        } else {
          tid(flashAll, 100);
        }
      };

      const flashAll = () => {
        els.forEach(el => { el.classList.remove('dim'); el.classList.add('glow'); });
        tid(() => {
          els.forEach(el => { el.classList.remove('glow'); el.classList.add('dim'); });
          tid(() => showLogo(false), 120);
        }, 260);
      };

      const showLogo = (instant = false) => {
        triggerGlitch();
        lb?.classList.add('show');
        lg?.classList.add('show');
        logoDomain?.classList.add('show');
        nrgs.forEach(n => n.classList.add('on'));
        corners.forEach(c => c?.classList.add('show'));
      };

      tid(streamBatch, 350);
    }

    resize();
    startIntro();
    window.addEventListener('resize', () => { resize(); initParticles(); }, { passive: true });
    
    document.addEventListener('astro:after-swap', () => {
      cancelAnimationFrame(rafId);
      clearTids();
    });
  }

  document.addEventListener('astro:page-load', initIntroAnimation);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initIntroAnimation);
  } else {
    initIntroAnimation();
  }
</script>
