---
import { t, type Lang } from '../i18n/utils';

export interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const trWords = [
  'e-fatura', 'e-dönüşüm', 'e-arşiv', 'e-defter',
  'e-imza', 'e-irsaliye', 'e-ödeme', 'e-tahsilat',
  'e-dbs', 'e-ekstre', 'e-ticaret', 'e-devlet',
  'e-checkout', 'e-mutabakat', 'e-sözleşme', 'e-tebligat',
  'e-bilet', 'e-analitik', 
  'e-loyalty', 'e-ihracat', 'e-cüzdan', 'e-muhasebe', 
  'e-lojistik', 'e-satınalma', 'e-öğrenme', 'e-sağlık',
  'e-anything', 'e-everything',
  'e-somting', 'e-somethingelse', 'e-any', 'e-any.com', 'ENY.COM.TR', 
];

const enWords = [
  'e-invoice', 'e-transformation', 'e-archive', 'e-ledger',
  'e-signature', 'e-waybill', 'e-payment', 'e-collection',
  'e-dds', 'e-statement', 'e-commerce', 'e-government',
  'e-checkout', 'e-reconciliation', 'e-contract', 'e-notification',
  'e-ticket', 'e-analytics', 
  'e-loyalty', 'e-export', 'e-wallet', 'e-accounting',
  'e-logistics', 'e-procurement', 'e-learning', 'e-health',
  'e-anything', 'e-everything',
  'e-somting', 'e-somethingelse', 'e-any', 'e-any.com', 'ENY.COM.TR', 
];

const words = lang === 'tr' ? trWords : enWords;
const wordsJson = JSON.stringify(words);

const introStatus = t('introStatus', lang);
---

<div id="intro-stage" data-lang={lang} data-words={wordsJson}>
  <canvas id="intro-bg"></canvas>
  <!-- Higgsfield-style Neon Glows -->
  <div class="neon-radial-glow top-left"></div>
  <div class="neon-radial-glow bottom-right"></div>
  <div id="grid-overlay"></div>
  <div id="vignette"></div>
  <div id="scan"></div>

  <div class="corner" id="c-tl"></div>
  <div class="corner" id="c-tr"></div>
  <div class="corner" id="c-bl"></div>
  <div class="corner" id="c-br"></div>

  <div id="intro-content">
    <div id="stream-area"></div>
    <!-- Premium Logo Block -->
    <div id="logo-block">
      <div id="logo-glow"></div>
      <div id="logo-image-container" class="flicker-logo">
        <div class="intro-logo-row flex items-center justify-center">
            <div class="intro-icon-wrapper relative">
                <div class="neon-glow-bg"></div>
                <img src="/images/logo/eny_icon.png" alt="eny" class="intro-logo-icon h-32 md:h-40 w-auto object-contain hidden-in-light" />
                <img src="/images/logo/eny_icon_black.png" alt="eny" class="intro-logo-icon h-32 md:h-40 w-auto object-contain hidden-in-dark" />
            </div>
            <div class="intro-text-wrapper">
                <span class="intro-wordmark text-[100px] md:text-[140px] font-extrabold tracking-tighter text-text-main" style="font-family: var(--font-sans)">eny<span class="intro-dot text-lime">.</span></span>
            </div>
        </div>
      </div>
      <div id="domains">
        <span class="dom">{lang === 'tr' ? 'eny.com.tr' : 'e-any.com'}</span>
      </div>
      <div id="tagline">{t('introTagline', lang)}</div>
      <div id="sub-tagline">{t('introSubTagline', lang)}</div>
      <p id="hero-desc">{t('introHeroDesc', lang)}</p>
      <div id="hero-ctas">
        <a href={lang === 'tr' ? '/iletisim' : '/en/contact'} class="cta-primary" id="cta-demo">{t('introCtaPrimary', lang)}</a>
        <a href="#platform" class="cta-ghost" id="cta-explore">{t('introCtaSecondary', lang)}</a>
      </div>
    </div>
  </div>

  <!-- Replay Button -->
  <button id="replay-btn">{t('introReplay', lang)}</button>
  <div id="status-bar" set:html={introStatus}></div>
</div>

<style>
  /* Intro Stage Scoped Styles */
  #intro-stage {
    width: 100%;
    height: 100vh;
    min-height: 700px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: transparent;
  }

  canvas#intro-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.6s;
  }

  #vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  :global([data-theme="dark"]) #vignette {
    background: radial-gradient(ellipse at center, transparent 25%, rgba(4,6,5,0.92) 100%);
  }
  :global([data-theme="light"]) #vignette {
    background: radial-gradient(ellipse at center, transparent 25%, rgba(240,245,236,0.7) 100%);
  }

  .neon-radial-glow {
    position: absolute;
    width: 60vw;
    height: 60vw;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(circle, var(--lime-glow) 0%, transparent 70%);
    transition: opacity 2s ease;
  }
  .neon-radial-glow.on { opacity: 0.12; }
  .top-left { top: -20%; left: -20%; }
  .bottom-right { bottom: -20%; right: -20%; }

  #grid-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transition: opacity 1s;
    pointer-events: none;
  }
  :global([data-theme="dark"]) #grid-overlay {
    background-image:
      linear-gradient(rgba(208,253,23,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(208,253,23,0.03) 1px, transparent 1px);
    background-size: 52px 52px;
  }
  :global([data-theme="light"]) #grid-overlay {
    background-image:
      linear-gradient(rgba(80,140,50,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(80,140,50,0.06) 1px, transparent 1px);
    background-size: 52px 52px;
  }
  #grid-overlay.on { opacity: 1; }

  #scan {
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    z-index: 2;
    top: 0;
    pointer-events: none;
    opacity: 0;
  }
  :global([data-theme="dark"]) #scan {
    background: linear-gradient(90deg, transparent, rgba(208,253,23,0.6), transparent);
  }
  :global([data-theme="light"]) #scan {
    background: linear-gradient(90deg, transparent, rgba(60,140,30,0.5), transparent);
  }

  #intro-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  #stream-area {
    width: 100%;
    max-width: 720px;
    min-height: 160px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px 14px;
    padding: 0 40px;
    margin-bottom: 52px;
  }

  :global(.sw) {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    color: var(--word-base);
    letter-spacing: 0.04em;
    opacity: 0;
    transform: translateY(4px);
    transition: all 0.35s cubic-bezier(0.22,1,0.36,1);
    white-space: nowrap;
    text-decoration: none;
    pointer-events: none;
  }
  :global(.sw.on) {
    opacity: 1;
    transform: translateY(0);
    color: var(--word-on);
    pointer-events: auto;
  }
  :global(.sw.on:hover) {
    color: var(--lime);
    transform: translateY(-2px) scale(1.05);
  }
  :global(.sw.glow) {
    color: var(--word-glow);
    text-shadow: 0 0 10px var(--lime-glow), 0 0 24px var(--lime-soft);
  }
  :global([data-theme="light"] .sw.glow) {
    text-shadow: 0 0 8px rgba(42,96,24,0.4);
  }
  :global(.sw.dim) {
    opacity: 1;
    color: var(--word-on);
    text-shadow: none;
  }
  :global(.sw.highlight) {
    font-weight: 600;
    font-size: 13px;
  }

  #logo-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    opacity: 0;
    transform: translateY(14px) scale(0.94);
    transition: opacity 0.9s cubic-bezier(0.22,1,0.36,1),
                transform 0.9s cubic-bezier(0.22,1,0.36,1);
    position: relative;
  }
  #logo-block.show {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  #logo-glow {
    position: absolute;
    width: 280px;
    height: 280px;
    background: var(--lime-glow);
    filter: blur(80px);
    opacity: 0;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: -1;
    transition: opacity 1.5s ease;
  }
  #logo-glow.show { opacity: 0.18; }
  :global([data-theme="light"]) #logo-glow.show { opacity: 0.08; background: #3a7a20; }

  #logo-image-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .intro-logo-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    animation: neon-flicker 4s infinite alternate;
  }

  @media (min-width: 768px) {
    .intro-logo-row {
      flex-direction: row;
      gap: clamp(0.5rem, 2vw, 1.5rem);
    }
  }

  .intro-logo-icon {
    height: clamp(100px, 20vw, 260px);
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 25px var(--lime-glow));
    transition: filter 0.6s, transform 0.6s;
  }

  .intro-wordmark {
    font-size: clamp(80px, 15vw, 180px);
    line-height: 1;
    letter-spacing: -0.06em;
    font-family: var(--font-sans);
    font-weight: 800;
    white-space: nowrap;
  }

  .intro-dot {
    display: inline-block;
    animation: dot-heartbeat 2.5s infinite;
    text-shadow: 0 0 20px var(--lime-glow);
  }

  /* Premium Neon Flicker Animation */
  @keyframes neon-flicker {
    0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% {
      opacity: 1;
      filter: drop-shadow(0 0 30px var(--lime-glow));
    }
    20%, 24%, 55% {
      opacity: 0.8;
      filter: drop-shadow(0 0 10px var(--lime-glow));
    }
    22% {
      opacity: 0.9;
      filter: drop-shadow(0 0 20px var(--lime-glow));
    }
  }

  /* Signature Dot Heartbeat */
  @keyframes dot-heartbeat {
    0%, 100% { transform: scale(1); opacity: 1; text-shadow: 0 0 25px var(--lime-glow); }
    50% { transform: scale(1.15); opacity: 0.8; text-shadow: 0 0 45px var(--lime-glow); }
  }

  .intro-logo:hover {
    transform: scale(1.02);
    filter: drop-shadow(0 0 50px var(--lime-glow));
  }
  :global([data-theme="light"]) #logo-dot { color: #3a7a20; text-shadow: none; }

  #domains {
    display: flex;
    gap: 20px;
    align-items: center;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.7s, transform 0.7s;
  }
  #domains.show { opacity: 1; transform: translateY(0); }

  .dom {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--domain-color);
    transition: color 0.6s;
  }
  .dom-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--border);
    transition: background 0.6s;
  }

  #tagline {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--tagline);
    opacity: 0;
    transition: opacity 0.8s, color 0.6s;
    margin-top: 2px;
  }
  #tagline.show { opacity: 1; }

  #sub-tagline {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    opacity: 0;
    margin-top: 6px;
    letter-spacing: 0.1em;
    transition: opacity 0.8s, transform 0.8s;
    text-align: center;
    text-transform: uppercase;
  }
  #sub-tagline.show { opacity: 0.9; }

  #slogan-line {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--lime);
    opacity: 0;
    margin-top: 14px;
    letter-spacing: 0.08em;
    transition: opacity 0.8s, transform 0.8s;
    text-align: center;
  }
  #slogan-line.show { opacity: 0.75; }

  #hero-desc {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 400;
    color: var(--text-70);
    max-width: 520px;
    text-align: center;
    line-height: 1.7;
    margin-top: 18px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.8s 0.1s, transform 0.8s 0.1s;
  }
  #hero-desc.show {
    opacity: 1;
    transform: translateY(0);
  }

  #hero-ctas {
    display: flex;
    gap: 14px;
    margin-top: 28px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.7s 0.2s, transform 0.7s 0.2s;
    flex-wrap: wrap;
    justify-content: center;
  }
  #hero-ctas.show {
    opacity: 1;
    transform: translateY(0);
  }

  .cta-primary {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    padding: 14px 32px;
    border-radius: 12px;
    background: var(--lime);
    color: #0A0F0D;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.22,1,0.36,1);
    letter-spacing: -0.01em;
    box-shadow: 0 0 24px rgba(208,253,23,0.15);
  }
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 32px rgba(208,253,23,0.35);
    background: #BCEB14;
  }

  .cta-ghost {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: 12px;
    background: transparent;
    color: var(--text-40);
    border: 1px solid var(--border);
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 12px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.22,1,0.36,1);
    letter-spacing: -0.01em;
  }
  .cta-ghost:hover {
    border-color: var(--lime);
    color: var(--lime);
    transform: translateY(-2px);
  }

  :global([data-theme="light"]) .cta-primary {
    background: #2a6018;
    color: #fff;
    box-shadow: 0 0 24px rgba(42,96,24,0.15);
  }
  :global([data-theme="light"]) .cta-primary:hover {
    box-shadow: 0 4px 32px rgba(42,96,24,0.35);
    background: #1f4c12;
  }

  .corner {
    position: absolute;
    width: 20px; height: 20px;
    opacity: 0;
    z-index: 3;
    transition: opacity 0.6s, border-color 0.6s;
    border-color: var(--corner);
    border-style: solid;
  }
  #c-tl { top: 22px; left: 22px; border-width: 1px 0 0 1px; }
  #c-tr { top: 22px; right: 22px; border-width: 1px 1px 0 0; }
  #c-bl { bottom: 22px; left: 22px; border-width: 0 0 1px 1px; }
  #c-br { bottom: 22px; right: 22px; border-width: 0 1px 1px 0; }
  .corner.show { opacity: 1; }

  #theme-btn {
    position: absolute;
    top: 22px; right: 64px;
    z-index: 10;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--btn-c);
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 5px 10px;
    cursor: pointer;
    letter-spacing: 0.06em;
    transition: color 0.3s, border-color 0.3s, background 0.3s;
    opacity: 0;
  }
  #theme-btn.show { opacity: 1; transition: opacity 0.6s, color 0.3s, border-color 0.3s; }
  #theme-btn:hover { color: var(--btn-h); border-color: var(--btn-h); }

  #replay-btn {
    position: absolute;
    bottom: 22px; right: 64px;
    z-index: 10;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--btn-c);
    background: none;
    border: none;
    cursor: pointer;
    letter-spacing: 0.08em;
    opacity: 0;
    transition: opacity 0.6s, color 0.3s;
  }
  #replay-btn.show { opacity: 1; }
  #replay-btn:hover { color: var(--btn-h); }

  #status-bar {
    position: absolute;
    bottom: 22px; left: 40px;
    z-index: 10;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--word-on);
    letter-spacing: 0.06em;
    opacity: 0;
    transition: opacity 0.6s, color 0.6s;
  }
  #status-bar.show { opacity: 1; }

  @media (max-width: 480px) {
    #stream-area { gap: 6px 10px; padding: 0 24px; font-size: 11px; }
    :global(.sw) { font-size: 11px; }
    #logo-text { font-size: 64px; }
    #theme-btn { right: 22px; }
    #replay-btn { right: 22px; }
    #status-bar { left: 22px; }
  }
</style>

<script>
  function initIntroAnimation() {
    const stage = document.getElementById('intro-stage');
    if (!stage) return;

    const lang = stage.getAttribute('data-lang') || 'tr';
    const WORDS = JSON.parse(stage.getAttribute('data-words') || '[]');

    const canvas = document.getElementById('intro-bg') as HTMLCanvasElement;
    if(!canvas) return;
    const ctx = canvas.getContext('2d');
    let W, H, particles = [], rafId, tids = [];

    function getTheme() { return document.documentElement.getAttribute('data-theme') || 'dark'; }

    function toggleTheme() {
      const current = getTheme();
      const t = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', t);
      localStorage.setItem('eny-theme', t);
      const btn = document.getElementById('theme-btn');
      if(btn) {
        btn.textContent = t === 'dark' 
          ? (lang === 'tr' ? '◐ tema' : '◐ theme') 
          : (lang === 'tr' ? '◑ tema' : '◑ theme');
      }
      initParticles();
    }

    const themeBtn = document.getElementById('theme-btn');
    if(themeBtn) themeBtn.addEventListener('click', toggleTheme);

    const replayBtn = document.getElementById('replay-btn');
    if(replayBtn) replayBtn.addEventListener('click', startIntro);

    function resize() {
      // make it responsive to parent
      const rect = stage.getBoundingClientRect();
      W = canvas.width = rect.width;
      H = canvas.height = rect.height;
    }

    function mkParticle() {
      return {
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.28,
        vy: (Math.random() - 0.5) * 0.28,
        r: Math.random() * 1.3 + 0.3,
        a: Math.random() * 0.5 + 0.1,
        lime: Math.random() < 0.14,
        pulse: Math.random() * Math.PI * 2
      };
    }

    function initParticles() {
      particles = [];
      const pCount = Math.min(130, Math.floor(W * H / 10000)); // responsive count
      for (let i = 0; i < pCount; i++) particles.push(mkParticle());
    }

    function drawBg() {
      if(!ctx) return;
      ctx.clearRect(0, 0, W, H);
      const dark = getTheme() === 'dark';

      const limeColor = dark
        ? (a) => `rgba(208,253,23,${a})`
        : (a) => `rgba(60,130,30,${a})`;
      const neutralColor = dark
        ? (a) => `rgba(60,90,65,${a})`
        : (a) => `rgba(120,170,90,${a})`;
      const lineColor = dark
        ? (a) => `rgba(42,61,46,${a})`
        : (a) => `rgba(120,170,90,${a})`;

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx; p.y += p.vy;
        p.pulse += 0.02;
        if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
        const pulse = 0.7 + Math.sin(p.pulse) * 0.3;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * pulse, 0, Math.PI * 2);
        ctx.fillStyle = p.lime
          ? limeColor(p.a * pulse * (dark ? 1 : 0.6))
          : neutralColor(p.a * 0.5 * pulse * (dark ? 1 : 0.7));
        ctx.fill();
      }

      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < 90) {
            const alpha = (1 - d / 90) * (dark ? 0.4 : 0.3);
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = lineColor(alpha);
            ctx.lineWidth = 0.4;
            ctx.stroke();
          }
        }
      }
      rafId = requestAnimationFrame(drawBg);
    }

    function clearTids() { tids.forEach(clearTimeout); tids = []; }

    let dotInterval;

    function startIntro() {
      clearTids();
      cancelAnimationFrame(rafId);
      clearInterval(dotInterval);

      const area = document.getElementById('stream-area');
      area.innerHTML = '';
      const els = [];
      
      const getLink = (word) => {
        const w = word.toLowerCase();
        if (w === 'e-any.com') return 'https://e-any.com';
        if (w === 'eny.com.tr') return 'https://eny.com.tr';
        
        if (lang === 'tr') {
          if (['e-fatura','e-arşiv','e-defter','e-irsaliye','e-ödeme','e-tahsilat','e-dbs','e-ekstre','e-checkout','e-mutabakat','e-sözleşme','e-tebligat','e-bilet','e-analitik'].includes(w)) return '/urunler';
          if (w === 'e-dönüşüm') return '/hizmetler';
          if (w === 'e-ticaret') return '/e-ticaret';
          if (w === 'e-devlet' || w === 'e-imza') return '/lokalizasyon';
          return '/urunler';
        } else {
          if (['e-invoice','e-archive','e-ledger','e-waybill','e-payment','e-collection','e-dbs','e-statement','e-checkout','e-reconciliation','e-contract','e-notification','e-ticket','e-analytics'].includes(w)) return '/en/products';
          if (w === 'e-transformation') return '/en/services';
          if (w === 'e-commerce') return '/e-ticaret';
          if (w === 'e-government' || w === 'e-signature') return '/en/rollout';
          return '/en/products';
        }
      };

      WORDS.forEach((w, i) => {
        const el = document.createElement('a');
        el.href = getLink(w);
        el.className = 'sw' + (i >= WORDS.length - 2 ? ' highlight' : '');
        el.textContent = w;
        // Only point to new tab for external domains
        if (w.includes('.com') || w.includes('.tr')) {
           el.target = "_blank";
           el.rel = "noopener noreferrer";
        }
        area.appendChild(el);
        els.push(el);
      });

      const lb = document.getElementById('logo-block');
      const lg = document.getElementById('logo-glow');
      const nrgs = document.querySelectorAll('.neon-radial-glow');
      const dom = document.getElementById('domains');
      const tag = document.getElementById('tagline');
      const subTag = document.getElementById('sub-tagline');
      const corners = ['c-tl','c-tr','c-bl','c-br'].map(id => document.getElementById(id));
      const statusBar = document.getElementById('status-bar');

      lb.classList.remove('show');
      if(lg) lg.classList.remove('show');
      nrgs.forEach(n => n.classList.remove('on'));
      dom.classList.remove('show');
      tag.classList.remove('show');
      subTag.classList.remove('show');
      const heroDescEl = document.getElementById('hero-desc');
      const heroCtasEl = document.getElementById('hero-ctas');
      if(heroDescEl) heroDescEl.classList.remove('show');
      if(heroCtasEl) heroCtasEl.classList.remove('show');
      if(replayBtn) replayBtn.classList.remove('show');
      statusBar.classList.remove('show');
      corners.forEach(c => c.classList.remove('show'));
      document.getElementById('grid-overlay').classList.remove('on');

      initParticles();
      rafId = requestAnimationFrame(drawBg);

      const scan = document.getElementById('scan');
      let scanPos = 0;
      scan.style.opacity = '1';
      scan.style.top = '0';
      const scanAnim = () => {
        scanPos += 2.5;
        scan.style.top = scanPos + 'px';
        if (scanPos < H) requestAnimationFrame(scanAnim);
        else scan.style.opacity = '0';
      };
      
      tids.push(setTimeout(() => {
        document.getElementById('grid-overlay').classList.add('on');
        requestAnimationFrame(scanAnim);
      }, 200));

      let i = 0;
      const step = () => {
        if (i < els.length) {
          const el = els[i];
          el.classList.add('on');
          tids.push(setTimeout(() => {
            el.classList.add('glow');
            tids.push(setTimeout(() => {
              el.classList.remove('glow');
              el.classList.add('dim');
            }, 480));
          }, 60));
          i++;
          const isLast2 = i >= els.length - 1;
          tids.push(setTimeout(step, isLast2 ? 220 : 85));
        } else {
          tids.push(setTimeout(flashAll, 320));
        }
      };

      const flashAll = () => {
        els.forEach((el, idx) => {
          tids.push(setTimeout(() => {
            el.classList.remove('dim');
            el.classList.add('glow');
          }, idx * 28));
        });
        tids.push(setTimeout(() => {
          els.forEach(el => { el.classList.remove('glow'); el.classList.add('dim'); });
          showLogo();
        }, els.length * 28 + 600));
      };

      const showLogo = () => {
        lb.classList.add('show');
        if(lg) lg.classList.add('show');
        nrgs.forEach(n => n.classList.add('on'));
        tids.push(setTimeout(() => { dom.classList.add('show'); }, 550));
        tids.push(setTimeout(() => { tag.classList.add('show'); }, 820));
        tids.push(setTimeout(() => { subTag.classList.add('show'); }, 1000));
        tids.push(setTimeout(() => {
          const slogan = document.getElementById('slogan-line');
          if(slogan) slogan.classList.add('show');
        }, 1100));
        tids.push(setTimeout(() => {
          const heroDesc = document.getElementById('hero-desc');
          if(heroDesc) heroDesc.classList.add('show');
        }, 1200));
        tids.push(setTimeout(() => {
          const heroCtas = document.getElementById('hero-ctas');
          if(heroCtas) heroCtas.classList.add('show');
        }, 1500));
        tids.push(setTimeout(() => { corners.forEach(c => c.classList.add('show')); }, 400));
        tids.push(setTimeout(() => {
          if(themeBtn) themeBtn.classList.add('show');
          if(replayBtn) replayBtn.classList.add('show');
          statusBar.classList.add('show');
          startDotPulse();
        }, 1600));
      };

      tids.push(setTimeout(step, 350));
    }

    function startDotPulse() {
      clearInterval(dotInterval);
      let on = true;
      dotInterval = setInterval(() => {
        const d = document.getElementById('logo-dot');
        if (d) d.style.opacity = on ? '1' : '0.15';
        on = !on;
      }, 950);
    }

    resize();
    startIntro();
    window.addEventListener('resize', () => { resize(); initParticles(); });
    
    // Cleanup on component unmount
    document.addEventListener('astro:after-swap', () => {
      cancelAnimationFrame(rafId);
      clearTids();
      clearInterval(dotInterval);
    });
  }

  // Support for Astro view transitions
  document.addEventListener('astro:page-load', initIntroAnimation);
  // Also run on first load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initIntroAnimation);
  } else {
    initIntroAnimation();
  }
</script>
