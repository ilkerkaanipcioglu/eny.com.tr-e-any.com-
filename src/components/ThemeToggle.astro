---
// ThemeToggle.astro — Dark/Light switch with localStorage persistence
---
<button
  class="theme-toggle-btn w-9 h-9 flex-shrink-0 rounded-lg flex items-center justify-center text-text-70 hover:text-text-main hover:bg-bg2 transition-colors cursor-pointer"
  aria-label="Toggle theme"
  title="Toggle dark/light theme"
>
  <!-- Sun icon (shown in dark mode) -->
  <span class="material-symbols-outlined text-[22px] theme-icon-sun">light_mode</span>
  <!-- Moon icon (shown in light mode) -->
  <span class="material-symbols-outlined text-[22px] theme-icon-moon">dark_mode</span>
</button>

<style>
  .theme-toggle-btn {
    position: relative;
    overflow: hidden;
  }
  .material-symbols-outlined {
    position: absolute;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }
  
  /* Initial states */
  [data-theme="dark"] .theme-icon-sun { transform: rotate(0deg); opacity: 1; }
  [data-theme="dark"] .theme-icon-moon { transform: rotate(90deg); opacity: 0; pointer-events: none; }

  [data-theme="light"] .theme-icon-sun { transform: rotate(-90deg); opacity: 0; pointer-events: none; }
  [data-theme="light"] .theme-icon-moon { transform: rotate(0deg); opacity: 1; }
</style>

<script>
  const toggles = document.querySelectorAll('.theme-toggle-btn');
  toggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('eny-theme', next);
    });
  });
</script>
