---
import { t, getLocalePath, type Lang } from '../i18n/utils';
import type { TranslationKey } from '../i18n/translations';
import ThemeToggle from './ThemeToggle.astro';
import { Mail, MessageSquare } from '@lucide/astro';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---
<footer class="bg-bg2 text-text-main pt-20 pb-8 px-8 md:px-12 relative overflow-hidden border-t border-border-main">
    <div class="max-w-container mx-auto relative z-10">
        <!-- Main Grid -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">
            <!-- Brand Column -->
            <div class="md:col-span-4">
                <div class="flex items-center gap-3 mb-6">
                    <!-- Spiral Icon (Theme Toggle) -->
                    <button class="theme-logo-toggle flex items-center justify-center transition-transform duration-500 hover:rotate-[360deg] cursor-pointer" aria-label="Toggle theme" title="Temayı Değiştir">
                        <img src="/images/logo/eny_icon.png" alt="eny" class="h-12 w-auto object-contain hidden-in-light" />
                        <img src="/images/logo/eny_icon_black.png" alt="eny" class="h-12 w-auto object-contain hidden-in-dark" />
                    </button>
                    <!-- Wordmark (Home Link) -->
                    <a href={getLocalePath('/', lang)} class="flex items-center group">
                        <span class="text-3xl font-extrabold tracking-tighter text-text-main group-hover:text-lime transition-colors duration-300" style="font-family: var(--font-sans)">eny<span class="text-lime">.</span></span>
                    </a>
                </div>
            </div>

            <!-- Quick Links -->
            <div class="md:col-span-2">
                <h4 class="font-sans font-medium text-text-main text-sm uppercase tracking-widest mb-6">{t('footerQuickLinks', lang)}</h4>
                <ul class="space-y-3">
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/hizmetler', lang)}>{t('navServices', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/lokalizasyon', lang)}>{t('navRollout', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/hakkimizda', lang)}>{t('navAbout', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/iletisim', lang)}>{t('navContact', lang)}</a></li>
                </ul>
            </div>

            <!-- Services -->
            <div class="md:col-span-3">
                <h4 class="font-sans font-medium text-text-main text-sm uppercase tracking-widest mb-6">{t('footerServices', lang)}</h4>
                <ul class="space-y-3">
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/e-ticaret', lang)}>{t('footerSvcCbc', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/e-dbs', lang)}>{t('footerSvcDbs', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/e-payment', lang)}>{t('footerSvcPay', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/e-cashflow', lang)}>{t('footerSvcCash', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/e-tahsilat', lang)}>{t('footerSvcEt', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/e-ekstre', lang)}>{t('footerSvcEks', lang)}</a></li>
                    <li><a class="text-text-70 text-sm hover:text-plum transition-colors font-light" href={getLocalePath('/e-pos', lang)}>{t('footerSvcPos', lang)}</a></li>
                </ul>
            </div>

        <div class="md:col-span-3">
                <p class="text-text-70 text-sm font-light">
                    {t('footerDesc', lang)}
                </p>
            <div class="flex gap-3 mt-4">
                {/* 1 - WhatsApp */}
                <a href="https://wa.me/905332388975" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-bg3 border border-border-main flex items-center justify-center text-text-40 hover:bg-[#25D366] hover:text-white transition-colors" title="WhatsApp">
                    <svg class="w-4 h-4 fill-current text-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                </a>
                {/* 2 - Telegram */}
                <a href="https://t.me/+905332388975" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-bg3 border border-border-main flex items-center justify-center text-text-40 hover:bg-[#26A5E4] hover:text-white transition-colors" title="Telegram">
                    <svg class="w-4 h-4 fill-current text-current" viewBox="0 0 24 24"><path d="m20.665 3.717-17.73 6.837c-1.21.486-1.203 1.161-.222 1.462l4.552 1.42 10.532-6.645c.498-.303.953-.14.579.192l-8.533 7.701h-.002l.002.001-.314 4.692c.46 0 .663-.211.921-.46l2.211-2.15 4.599 3.397c.848.467 1.457.227 1.668-.785l3.019-14.228c.309-1.239-.473-1.8-1.282-1.434z"/></svg>
                </a>
                {/* 3 - LinkedIn */}
                <a href="https://www.linkedin.com/company/eny/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-bg3 border border-border-main flex items-center justify-center text-text-40 hover:bg-[#0077b5] hover:text-white transition-colors" title="LinkedIn">
                    <svg class="w-4 h-4 fill-current text-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
                {/* 4 - Email */}
                <a href="mailto:info@eny.com.tr" class="w-10 h-10 rounded-xl bg-bg3 border border-border-main flex items-center justify-center text-text-40 hover:bg-plum hover:text-white transition-colors" title="Email">
                    <Mail size={18} class="lucide-icon" />
                </a>
            </div>
               <!-- Social & Context Bar -->
        <div class="border-t border-border-main py-8 flex flex-wrap items-center justify-between gap-6 text-xs text-text-40">
            <div class="flex items-center gap-6">
                <a href="https://wa.me/905332388975" target="_blank" class="hover:text-lime transition-colors flex items-center gap-2">
                   <MessageSquare size={18} class="lucide-icon" /> WhatsApp
                </a>
                <a href="mailto:info@eny.com.tr" class="hover:text-lime transition-colors flex items-center gap-2">
                   <Mail size={18} class="lucide-icon" /> info@eny.com.tr
                </a>
            </div>
            <div class="flex items-center gap-6">
                <a href="https://www.linkedin.com/company/eny/" target="_blank" class="hover:text-lime transition-colors font-bold text-text-70">LinkedIn</a>
                <a href="#" class="hover:text-lime transition-colors text-text-40 opacity-50">X / Twitter</a>
            </div>
        </div>
        </div>

        <!-- Bottom Bar -->
        <div class="border-t border-border-main pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left font-mono uppercase">
            <div class="flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-lime animate-pulse"></span>
                <span class="text-[10px] text-lime tracking-widest uppercase">{lang === 'tr' ? 'Sistem Durumu: Operasyonel' : 'System Status: Operational'}</span>
            </div>
            <span class="text-[10px] text-text-40 tracking-widest">© 2026 ENY INFRASTRUCTURE. ALL RIGHTS RESERVED.</span>
            <div class="flex flex-wrap justify-center md:justify-end items-center gap-4 md:gap-8 text-xs text-text-40">
                <a class="hover:text-plum transition-colors" href={getLocalePath('/kvkk', lang)}>{t('footerKvkk', lang)}</a>
                <a class="hover:text-plum transition-colors" href={getLocalePath('/gizlilik-politikasi', lang)}>{t('footerPrivacy', lang)}</a>
                <a class="hover:text-plum transition-colors" href={getLocalePath('/cerez-politikasi', lang)}>{t('footerCookies', lang)}</a>
            </div>
        </div>
    </div>
</footer>
