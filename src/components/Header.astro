---
import { t, getLocalePath, getAlternateLangPath, type Lang } from '../i18n/utils';
import type { TranslationKey } from '../i18n/translations';
import ThemeToggle from './ThemeToggle.astro';
import { 
  Check,
  Globe,
  Quote,
  Moon,
  Sun,
  MessageSquare,
  ChevronDown,
  ChevronRight,
  Wallet,
  Fish,
  Bird,
  Sprout,
  Shell,
  Waves,
  Leaf,
  Sparkles,
  ArrowRight,
  Menu,
  X,
  LayoutDashboard,
  Grid3x3
} from '@lucide/astro';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems: { label: string; enLabel: string; path: string }[] = [
  { label: 'Çözümler', enLabel: 'Solutions', path: '/urunler' },
  { label: 'Hizmetler', enLabel: 'Services', path: '/hizmetler' },
  { label: 'Teknoloji', enLabel: 'Technology', path: '/teknoloji' },
];

function isActivePath(itemPath: string): boolean {
  const localePath = getLocalePath(itemPath, lang);
  return currentPath === localePath || currentPath === localePath + '/';
}

const alternateLangPath = getAlternateLangPath(currentPath, lang);
const otherLang = lang === 'tr' ? 'EN' : 'TR';
const isHomePage = currentPath === '/' || currentPath === '/en' || currentPath === '/en/';
---
<nav class={`fixed top-0 w-full z-50 glass-nav transition-all duration-700 ${!isHomePage ? 'scrolled forced-show' : 'opacity-0 -translate-y-4 pointer-events-none'}`} id="main-nav" data-is-home={isHomePage ? 'true' : 'false'}>
    <div class="flex justify-between items-center px-8 md:px-12 py-3.5 max-w-container mx-auto relative z-20">
        <!-- Consolidated Logo & Theme Toggle -->
        <div class="flex items-center gap-3">
            <!-- Spiral Icon (Theme Toggle) -->
            <button class="theme-logo-toggle flex items-center justify-center transition-transform duration-500 hover:rotate-[360deg] cursor-pointer" aria-label="Toggle theme" title="Temayı Değiştir">
                <img src="/images/logo/eny_icon.png" alt="eny" class="h-10 md:h-11 w-auto object-contain hidden-in-light" />
                <img src="/images/logo/eny_icon_black.png" alt="eny" class="h-10 md:h-11 w-auto object-contain hidden-in-dark" />
            </button>
            <!-- Wordmark (Home Link) -->
            <a href={getLocalePath('/', lang)} class="flex items-center group">
                <span class="text-xl md:text-2xl font-extrabold tracking-tighter text-text-main group-hover:text-accent-text transition-colors duration-300" style="font-family: var(--font-sans)">eny<span class="text-lime">.</span></span>
            </a>
        </div>
        <!-- Navigation (Desktop) -->
        <div class="hidden md:flex items-center space-x-2 h-[50px]">
            
            <!-- Çözümler Dropdown (Mega Menu) -->
            <div class="relative group h-full flex items-center">
                <button class={`flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-bold transition-all duration-300 cursor-default ${isActivePath('/urunler') ? 'bg-nav-pill-bg text-nav-pill-text shadow-sm' : 'text-text-70 group-hover:text-accent-text'}`}>
                    {t('navSolutions', lang)}
                    <ChevronDown size={18} class="group-hover:rotate-180 transition-transform duration-300" />
                </button>
                
                <!-- Mega Menu Panel -->
                <div class="absolute top-full -translate-x-1/3 pt-4 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60]">
                    <!-- Bridge (invisible area so hover doesn't break) -->
                    <div class="absolute -top-4 left-0 w-full h-4"></div>
                    
                    <div class="bg-bg shadow-[0_16px_50px_rgba(0,0,0,0.15)] border border-border rounded-2xl w-[950px] flex flex-row overflow-hidden backdrop-blur-3xl">
                        
                        <!-- Left Side: Product Links -->
                        <div class="flex-[4] p-8 bg-bg/95">
                            <h4 class="text-xs font-bold tracking-widest text-text-40 uppercase mb-5">{lang === 'tr' ? 'E-Dönüşüm & Altyapı Çözümleri' : 'E-Transformation & Solutions'}</h4>
                            <div class="grid grid-cols-2 gap-x-4 gap-y-1">
                                <a href={getLocalePath('/urunler', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Wallet size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'eny Nakit Yönetimi' : 'Cash Management Hub'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Banka Hub, e-Tahsilat, MT940 mutabakatı ve DBS süreçlerini iş yazılımınızdan çıkmadan tek panelde yönetin.' : 'Manage Bank Hub, e-Collection, MT940 reconciliation directly within your business software.'}</p>
                                    </div>
                                </a>
                                
                                <a href={getLocalePath('/urunler', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Leaf size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'e-Devlet Serisi Çözümleri' : 'e-Government Series'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Tam uyumlu e-Fatura, e-Defter, e-İrsaliye çözümlerini mevcut muhasebe sisteminiz üzerine kurun.' : 'Install fully compliant e-Invoice and e-Ledger solutions naturally on your accounting system.'}</p>
                                    </div>
                                </a>

                                <a href={getLocalePath('/e-ticaret', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Sprout size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'e-Ticaret & Pazaryeri' : 'e-Commerce & Marketplace'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Shopify ve pazaryeri siparişlerini, ödeme ve komisyon süreçleriyle tam entegre yönetin.' : 'Manage Shopify and marketplace orders, including payment and commission flows.'}</p>
                                    </div>
                                </a>



                                <a href={getLocalePath('/e-tahsilat', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Shell size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'E-Tahsilat Platformu' : 'E-Collection Platform'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Müşteri ve bayilerinizden saniyeler içinde güvenli online ödeme alın.' : 'Collect secure online payments from customers and dealers in seconds.'}</p>
                                    </div>
                                </a>

                                <a href={getLocalePath('/e-ekstre', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Bird size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'E-Ekstre & Açık Bankacılık' : 'E-Statement & Open Banking'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Tüm banka hesaplarını tek panelden yöneten Açık Bankacılık çözümü.' : 'Open Banking solution that manages all bank accounts from a single panel.'}</p>
                                    </div>
                                </a>

                                <a href={getLocalePath('/e-pos', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Sparkles size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'E-POS Takip & Raporlama' : 'E-POS Tracking & Reporting'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Fiziksel ve sanal POS hareketlerini tek panelden yöneten raporlama çözümü.' : 'Reporting solution that manages physical and virtual POS movements from a single panel.'}</p>
                                    </div>
                                </a>

                                <a href={getLocalePath('/e-dbs', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Grid3x3 size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'E-DBS Sistemi' : 'E-DBS System'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Çok bankalı Doğrudan Borçlandırma Sistemi süreçlerinizi tek panelden yönetin.' : 'Manage your multi-bank Direct Debit System processes from a single panel.'}</p>
                                    </div>
                                </a>

                                <a href={getLocalePath('/e-payment', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Bird size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'E-Ödeme (TÖS)' : 'E-Payment (Bulk)'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Toplu ödemelerinizi tüm bankalara aynı anda güvenle iletin.' : 'Securely send your bulk payments to all banks simultaneously.'}</p>
                                    </div>
                                </a>

                                <a href={getLocalePath('/e-cashflow', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <Fish size={24} class="lucide-icon icon-bounce-hover" />
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'E-Nakit Akışı' : 'E-Cash Flow'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Finansal görünürlük ve yapay zeka destekli nakit tahminleme platformu.' : 'Financial visibility and AI-powered cash forecasting platform.'}</p>
                                    </div>
                                </a>
                            </div>
                        </div>
                        
                        <!-- Right Side: Promo Action Card -->
                        <div class="flex-[1.5] bg-lime p-8 text-black relative flex flex-col justify-end overflow-hidden shadow-inner font-mono">
                            <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.1]"></div>
                            <div class="absolute top-0 right-0 w-32 h-32 bg-black/5 rounded-full blur-[40px]"></div>
                            
                            <div class="relative z-10 text-left">
                                <div class="w-10 h-10 rounded-full bg-black/10 flex items-center justify-center mb-6">
                                    <LayoutDashboard size={20} class="text-black icon-bounce-hover" />
                                </div>
                                <h4 class="font-bold text-xl mb-3 leading-tight uppercase tracking-tighter">{lang === 'tr' ? 'eny ile Finansal Dönüşüm' : 'Financial Transformation with eny'}</h4>
                                <p class="text-[13px] text-black/70 leading-relaxed mb-6 font-medium">
                                    {lang === 'tr' ? 'Maliyetli manuel bankacılık ve muhasebe operasyonlarınızı yüksek performanslı platformumuzla uçtan uca dönüştürüyoruz.' : 'Transform your costly manual banking and accounting operations end-to-end with our high-performance platform.'}
                                </p>
                                <a href={getLocalePath('/iletisim', lang)} class="inline-flex w-full items-center justify-center gap-2 px-5 py-3 rounded-xl bg-black text-white font-bold text-xs uppercase tracking-widest hover:shadow-xl hover:-translate-y-0.5 transition-all">
            {t('navCta', lang)}
                                    <ArrowRight size={16} />
                                </a>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </div>

            <!-- Hizmetlerimiz Dropdown (Mega Menu) -->
            <div class="relative group h-full flex items-center">
                <button class={`flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-bold transition-all duration-300 cursor-default ${isActivePath('/hizmetler') ? 'bg-nav-pill-bg text-nav-pill-text shadow-sm' : 'text-text-70 group-hover:text-accent-text'}`}>
                    {lang === 'tr' ? 'Hizmetlerimiz' : 'Services'}
                    <ChevronDown size={18} class="group-hover:rotate-180 transition-transform duration-300" />
                </button>
                
                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60]">
                    <div class="absolute -top-4 left-0 w-full h-4"></div>
                    <div class="bg-bg shadow-[0_16px_50px_rgba(0,0,0,0.15)] border border-border rounded-2xl w-[850px] flex overflow-hidden backdrop-blur-3xl">
                        
                        <!-- Left Side: Service Links -->
                        <div class="flex-[3] p-8 bg-bg/95 grid grid-cols-2 gap-8">
                            <!-- Col 1 -->
                            <div>
                                <h4 class="text-[11px] font-bold tracking-widest text-lime uppercase mb-5 flex items-center gap-2">
                                    <Shell size={16} class="lucide-icon" /> {lang === 'tr' ? 'Endüstri Çözümleri' : 'Industry Solutions'}
                                </h4>
                                <ul class="space-y-3.5">
                                    <li><a href={getLocalePath('/hizmetler/e-donusum', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('footerSvcTv', lang)}</a></li>
                                    <li><a href={getLocalePath('/e-dbs', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('footerSvcGci', lang)}</a></li>
                                    <li><a href={getLocalePath('/e-ticaret', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('footerSvcCbc', lang)}</a></li>
                                    <li><a href={getLocalePath('/pazaryeri-cozumu', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('footerSvcMp', lang)}</a></li>
                                    <li><a href={getLocalePath('/e-tahsilat', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('footerSvcEt', lang)}</a></li>
                                    <li><a href={getLocalePath('/e-ekstre', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('footerSvcEks', lang)}</a></li>
                                    <li><a href={getLocalePath('/e-pos', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('footerSvcPos', lang)}</a></li>
                                    <li><a href={getLocalePath('/e-dbs', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('footerSvcCt', lang)}</a></li>
                                </ul>
                            </div>

                            <!-- Col 2 -->
                            <div>
                                <h4 class="text-[11px] font-bold tracking-widest text-lime uppercase mb-5 flex items-center gap-2">
                                    <Grid3x3 size={16} class="lucide-icon" /> {lang === 'tr' ? 'Platform & Destek' : 'Platform & Support'}
                                </h4>
                                <ul class="space-y-3.5">
                                    <li><a href={getLocalePath('/iletisim', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'API Dokümantasyonu' : 'API Documentation'}</a></li>
                                    <li><a href={getLocalePath('/iletisim', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'Sistem Entegrasyonu' : 'System Integration'}</a></li>
                                </ul>
                            </div>
                        </div>
                        
                        <!-- Right Side: Promo Action Card -->
                        <div class="flex-[1.2] bg-bg2 p-8 relative flex flex-col overflow-hidden border-l border-border">
                            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-lime/10 rounded-full blur-[40px]"></div>
                            <div class="relative z-10 text-left h-full flex flex-col">
                                <Wallet size={32} class="text-lime mb-4 lucide-icon icon-bounce-hover" />
                                <h4 class="font-bold text-lg mb-2 text-text-main">{lang === 'tr' ? 'Mükemmel Mimari' : 'Flawless Architecture'}</h4>
                                <p class="text-[13px] text-text-70 leading-relaxed font-light flex-grow">
                                    {lang === 'tr' ? 'Tüm finansal yapınızı uçtan uca tek sistem üzerinde sıfır manuel iş prensibiyle tasarlıyoruz.' : 'We design your entire financial structure end-to-end on a single system with zero manual work.'}
                                </p>
                                <a href={getLocalePath('/hizmetler', lang)} class="inline-flex items-center gap-1.5 text-xs font-bold text-lime hover:text-white transition-colors">
                                    {lang === 'tr' ? 'Tüm Hizmetleri Gör' : 'View All Services'} <ArrowRight size={14} />
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Kurumsal Dropdown -->
            <div class="relative group h-full flex items-center">
                <button class={`flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-bold transition-all duration-300 cursor-default ${(isActivePath('/hakkimizda') || isActivePath('/sektorler') || isActivePath('/insight')) ? 'bg-nav-pill-bg text-nav-pill-text shadow-sm' : 'text-text-70 group-hover:text-accent-text'}`}>
                    {t('navAbout', lang)}
                    <ChevronDown size={18} class="group-hover:rotate-180 transition-transform duration-300" />
                </button>
                
                <div class="absolute top-full -translate-x-2/3 pt-4 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60]">
                    <div class="absolute -top-4 left-0 w-full h-4"></div>
                    <div class="bg-bg/95 shadow-[0_16px_50px_rgba(0,0,0,0.15)] border border-border rounded-2xl w-[500px] flex overflow-hidden backdrop-blur-3xl p-8 grid grid-cols-2 gap-8">
                        <div>
                            <h4 class="text-[11px] font-bold tracking-widest text-text-40 uppercase mb-5 flex items-center gap-2">
                                <Bird size={16} class="lucide-icon" /> {lang === 'tr' ? 'Hakkımızda' : 'About Us'}
                            </h4>
                            <ul class="space-y-3.5">
                                <li><a href={getLocalePath('/hakkimizda', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-semibold">{t('navAbout', lang)}</a></li>
                                <li><a href={getLocalePath('/sektorler', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('navSectors', lang)}</a></li>
                                <li><a href={getLocalePath('/iletisim', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{t('navContact', lang)}</a></li>
                            </ul>
                        </div>
                        <div>
                            <h4 class="text-[11px] font-bold tracking-widest text-text-40 uppercase mb-5 flex items-center gap-2">
                                <Leaf size={16} class="lucide-icon" /> {lang === 'tr' ? 'İçerik & Yasal' : 'Insights & Legal'}
                            </h4>
                            <ul class="space-y-3.5">
                                <li><a href={getLocalePath('/insight', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">eny Insight</a></li>
                                <li><a href={getLocalePath('/kvkk', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium text-text-70">KVKK / Aydınlatma</a></li>
                                <li><a href={getLocalePath('/gizlilik-politikasi', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium text-text-70">{lang === 'tr' ? 'Gizlilik Politikası' : 'Privacy Policy'}</a></li>
                                <li><a href={getLocalePath('/cerez-politikasi', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium text-text-70">{lang === 'tr' ? 'Çerez Politikası' : 'Cookie Policy'}</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Right Actions -->
        <div class="flex items-center gap-2 md:gap-4">

             
            <!-- Lang Dropdown (Desktop) -->
            <div class="relative group hidden lg:flex h-full items-center">
                <button class="flex items-center gap-1.5 px-2 py-2 rounded-lg text-sm font-medium text-text-70 group-hover:text-text-main hover:bg-bg2 transition-colors duration-200">
                    <Globe size={18} />
                    {lang === 'tr' ? 'TR' : 'EN'}
                    <ChevronDown size={18} class="text-text-40 group-hover:rotate-180 transition-transform duration-300" />
                </button>
                <div class="absolute top-full right-0 pt-4 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60]">
                    <div class="absolute -top-4 right-0 w-full h-4"></div>
                    <div class="bg-bg/95 shadow-[0_16px_50px_rgba(0,0,0,0.15)] border border-border rounded-xl w-[140px] flex py-2 flex-col overflow-hidden backdrop-blur-3xl">
                        <a href={getAlternateLangPath(currentPath, 'en')} class={`px-4 py-2.5 text-sm font-medium transition-colors flex items-center justify-between ${lang === 'tr' ? 'text-lime bg-lime/10 font-bold' : 'text-text-70 hover:bg-bg2 hover:text-text-main'}`} data-lang-switcher="tr">
                            Türkçe 
                            {lang === 'tr' && <Check size={16} />}
                        </a>
                        <a href={getAlternateLangPath(currentPath, 'tr')} class={`px-4 py-2.5 text-sm font-medium transition-colors flex items-center justify-between ${lang === 'en' ? 'text-lime bg-lime/10 font-bold' : 'text-text-70 hover:bg-bg2 hover:text-text-main'}`} data-lang-switcher="en">
                            English
                            {lang === 'en' && <Check size={16} />}
                        </a>
                    </div>
                </div>
            </div>
            <!-- CTA (Desktop) -->
            <a href={getLocalePath('/iletisim', lang)} class="hidden sm:inline-block bg-lime text-black px-5 py-2.5 rounded-lg font-bold text-xs uppercase tracking-widest hover:bg-white hover:shadow-[0_0_20px_rgba(208,253,23,0.3)] transition-all">
                {t('navCta', lang)}
            </a>
            
            <!-- Hamburger Button (Mobile) -->
            <button id="mobile-menu-btn" class="md:hidden flex flex-col items-center justify-center w-10 h-10 text-text-main hover:bg-bg2 rounded-lg transition-colors focus:outline-none" aria-label="Menu Toggle">
                <Menu size={28} id="menu-icon" />
            </button>
        </div>
    </div>
    
    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="absolute top-full left-0 w-full bg-bg/95 backdrop-blur-xl border-t border-border-main shadow-2xl transition-all duration-300 ease-in-out opacity-0 -translate-y-4 pointer-events-none md:hidden flex flex-col px-8 py-6 gap-2 h-[calc(100vh-70px)] overflow-y-auto z-10">
        {navItems.map((item) => (
             <a
               class={`flex items-center px-4 py-3.5 rounded-xl text-lg font-medium transition-all duration-200 ${
                 isActivePath(item.path)
                   ? 'text-lime bg-lime/10 font-bold border-l-4 border-lime'
                   : 'text-text-main hover:text-lime hover:bg-bg2'
               }`}
               href={getLocalePath(item.path, lang)}
             >
               {lang === 'tr' ? item.label : item.enLabel}
             </a>
        ))}
        
        <div class="mt-4 mb-2 h-px w-full bg-border-main"></div>

        <!-- CTA (Mobile) -->
        <a href={getLocalePath('/iletisim', lang)} class="w-full text-center bg-lime text-black px-6 py-4 rounded-xl font-bold text-sm uppercase tracking-widest hover:bg-white transition-all shadow-lg flex items-center justify-center gap-2">
            {t('navCta', lang)}
            <ArrowRight size={20} />
        </a>
        


        <!-- Lang Toggle (Mobile) -->
        <div class="mt-4 flex items-center justify-center bg-bg2 rounded-full p-1.5 gap-1 w-full max-w-[240px] mx-auto border border-border-main">
             {lang === 'tr' ? (
                 <>
                     <span class="px-6 py-2.5 rounded-full bg-lime text-black text-sm font-bold tracking-wide w-1/2 text-center">TR</span>
                     <a href={`https://e-any.com${alternateLangPath}`} class="px-6 py-2.5 rounded-full text-text-40 text-sm font-bold tracking-wide hover:text-text-main transition-colors w-1/2 text-center" data-lang-switcher="en">EN</a>
                 </>
             ) : (
                 <>
                     <a href={`https://eny.com.tr${alternateLangPath}`} class="px-6 py-2.5 rounded-full text-text-40 text-sm font-bold tracking-wide hover:text-text-main transition-colors w-1/2 text-center" data-lang-switcher="tr">TR</a>
                     <span class="px-6 py-2.5 rounded-full bg-lime text-black text-sm font-bold tracking-wide w-1/2 text-center">EN</span>
                 </>
             )}
        </div>
    </div>
</nav>

<script>
  // Scroll visibility effect
  const nav = document.getElementById('main-nav');
  const isHome = nav ? nav.getAttribute('data-is-home') === 'true' : true;

  window.addEventListener('scroll', () => {
    if (nav) {
      if (window.scrollY > 5) {
        nav.classList.add('scrolled', 'forced-show');
        nav.classList.remove('opacity-0', '-translate-y-4', 'pointer-events-none');
      }
    }
  });

  // Mobile Menu Toggle
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  
  if (mobileBtn && mobileMenu && menuIcon) {
    mobileBtn.addEventListener('click', () => {
      const isExpanded = mobileMenu.classList.contains('opacity-100');
      if (isExpanded) {
        mobileMenu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        mobileMenu.classList.add('opacity-0', '-translate-y-4', 'pointer-events-none');
        menuIcon.textContent = 'menu';
        document.body.style.overflow = '';
      } else {
        mobileMenu.classList.remove('opacity-0', '-translate-y-4', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        menuIcon.textContent = 'close';
        document.body.style.overflow = 'hidden';
      }
    });
  }

  // Language Preference Persistence
  document.querySelectorAll('[data-lang-switcher]').forEach(el => {
    el.addEventListener('click', (e) => {
      const newLang = el.getAttribute('data-lang-switcher');
      if (newLang) {
        localStorage.setItem('eny-lang-pref', newLang);
      }
    });
  });

  // Theme Toggle via Logo Icon
  document.querySelectorAll('.theme-logo-toggle').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('eny-theme', next);
      
      // Spin animation on toggle
      btn.style.transform = 'rotate(360deg)';
      setTimeout(() => { btn.style.transform = ''; }, 500);
    });
  });
</script>
