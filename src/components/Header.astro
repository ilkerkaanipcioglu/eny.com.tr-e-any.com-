---
import { t, getLocalePath, getAlternateLangPath, type Lang } from '../i18n/utils';
import type { TranslationKey } from '../i18n/translations';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems: { label: string; enLabel: string; path: string }[] = [
  { label: 'Çözümler', enLabel: 'Solutions', path: '/urunler' },
  { label: 'Hizmetler', enLabel: 'Services', path: '/hizmetler' },
  { label: 'Kurumsal', enLabel: 'Corporate', path: '/hakkimizda' },
  { label: 'eny Insight', enLabel: 'Insight', path: '/insight' },
];

function isActivePath(itemPath: string): boolean {
  const localePath = getLocalePath(itemPath, lang);
  return currentPath === localePath || currentPath === localePath + '/';
}

const alternateLangPath = getAlternateLangPath(currentPath, lang);
const otherLang = lang === 'tr' ? 'EN' : 'TR';
const isHomePage = currentPath === '/' || currentPath === '/en' || currentPath === '/en/';
---
<nav class={`fixed top-0 w-full z-50 glass-nav ${!isHomePage ? 'scrolled forced-show' : ''}`} id="main-nav" data-is-home={isHomePage ? 'true' : 'false'}>
    <div class="flex justify-between items-center px-8 md:px-12 py-3.5 max-w-container mx-auto relative z-20">
        <!-- Logo -->
        <div class="flex items-center">
            <a href={getLocalePath('/', lang)} class="flex items-center group relative">
                <img src="/images/logo/eny_icon.png" alt="eny" class="h-10 md:h-11 w-auto object-contain hidden-in-light transition-transform duration-300 group-hover:scale-110" />
                <img src="/images/logo/eny_icon_black.png" alt="eny" class="h-10 md:h-11 w-auto object-contain hidden-in-dark transition-transform duration-300 group-hover:scale-110" />
            </a>
        </div>
        <!-- Navigation (Desktop) -->
        <div class="hidden md:flex items-center space-x-2 h-[50px]">
            
            <!-- Çözümler Dropdown (Mega Menu) -->
            <div class="relative group h-full flex items-center">
                <button class={`flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200 cursor-default ${isActivePath('/urunler') ? 'text-lime font-semibold' : 'text-text-70 group-hover:text-text-main'}`}>
                    {lang === 'tr' ? 'Çözümlerımız' : 'Solutions'}
                    <span class="material-symbols-outlined text-[18px] text-text-40 group-hover:rotate-180 transition-transform duration-300">keyboard_arrow_down</span>
                </button>
                
                <!-- Mega Menu Panel -->
                <div class="absolute top-full -translate-x-1/3 pt-4 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60]">
                    <!-- Bridge (invisible area so hover doesn't break) -->
                    <div class="absolute -top-4 left-0 w-full h-4"></div>
                    
                    <div class="bg-bg shadow-[0_16px_50px_rgba(0,0,0,0.15)] border border-border rounded-2xl w-[750px] flex flex-row overflow-hidden backdrop-blur-3xl">
                        
                        <!-- Left Side: Product Links -->
                        <div class="flex-[3] p-8 bg-bg/95">
                            <h4 class="text-xs font-bold tracking-widest text-text-40 uppercase mb-5">{lang === 'tr' ? 'E-Dönüşüm & Altyapı' : 'E-Transformation & Infra'}</h4>
                            <div class="space-y-1.5">
                                <a href={getLocalePath('/urunler', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <span class="material-symbols-outlined text-2xl">account_balance_wallet</span>
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'eny Nakit Yönetimi' : 'Cash Management Hub'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Banka Hub, e-Tahsilat, MT940 mutabakatı ve DBS süreçlerini SAP içinden çıkmadan tek panelde yönetin.' : 'Manage Bank Hub, e-Collection, MT940 reconciliation directly within SAP.'}</p>
                                    </div>
                                </a>
                                
                                <a href={getLocalePath('/urunler', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <span class="material-symbols-outlined text-2xl">receipt_long</span>
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'e-Devlet Serisi Çözümleri' : 'e-Government Series'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Tam uyumlu e-Fatura, e-Defter, e-İrsaliye çözümlerini %100 SAP FI modülü üzerine kurun.' : 'Install fully compliant e-Invoice and e-Ledger solutions naturally on SAP FI.'}</p>
                                    </div>
                                </a>

                                <a href={getLocalePath('/e-ticaret', lang)} class="flex items-start gap-4 p-3.5 rounded-xl hover:bg-bg2 transition-colors group/item">
                                    <div class="w-11 h-11 rounded-lg bg-lime/10 text-lime flex items-center justify-center shrink-0 group-hover/item:scale-110 transition-transform">
                                        <span class="material-symbols-outlined text-2xl">storefront</span>
                                    </div>
                                    <div class="flex-1">
                                        <h5 class="font-bold text-text-main text-[15px] mb-1 group-hover/item:text-lime transition-colors">{lang === 'tr' ? 'Pazaryeri & e-Ticaret' : 'Commerce & Marketplace'}</h5>
                                        <p class="text-[13px] text-text-70 leading-relaxed font-light">{lang === 'tr' ? 'Shopify, Trendyol ve Hepsiburada siparişlerini otomatik faturalaştırıp muhasebeleşmesini sağlayın.' : 'Automatically invoice and account Shopify, Trendyol and other marketplace orders.'}</p>
                                    </div>
                                </a>
                            </div>
                        </div>
                        
                        <!-- Right Side: Promo Action Card -->
                        <div class="flex-[2] bg-lime p-8 text-black relative flex flex-col justify-end overflow-hidden shadow-inner font-mono">
                            <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.1]"></div>
                            <div class="absolute top-0 right-0 w-32 h-32 bg-black/5 rounded-full blur-[40px]"></div>
                            
                            <div class="relative z-10 text-left">
                                <div class="w-10 h-10 rounded-full bg-black/10 flex items-center justify-center mb-6">
                                    <span class="material-symbols-outlined text-black text-xl">account_balance</span>
                                </div>
                                <h4 class="font-bold text-xl mb-3 leading-tight uppercase tracking-tighter">{lang === 'tr' ? 'eny ile Finansal Dönüşüm' : 'Financial Transformation with eny'}</h4>
                                <p class="text-[13px] text-black/70 leading-relaxed mb-6 font-medium">
                                    {lang === 'tr' ? 'Maliyetli manuel bankacılık ve muhasebe operasyonlarınızı yüksek performanslı platformumuzla uçtan uca dönüştürüyoruz.' : 'Transform your costly manual banking and accounting operations end-to-end with our high-performance platform.'}
                                </p>
                                <a href={getLocalePath('/iletisim', lang)} class="inline-flex w-full items-center justify-center gap-2 px-5 py-3 rounded-xl bg-black text-white font-bold text-xs uppercase tracking-widest hover:shadow-xl hover:-translate-y-0.5 transition-all">
                                    {lang === 'tr' ? 'Projenizi Konuşalım' : 'Let\'s Talk Project'}
                                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                                </a>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </div>

            <!-- Hizmetlerimiz Dropdown (Mega Menu) -->
            <div class="relative group h-full flex items-center">
                <button class={`flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200 cursor-default ${isActivePath('/hizmetler') ? 'text-lime font-semibold' : 'text-text-70 group-hover:text-text-main'}`}>
                    {lang === 'tr' ? 'Hizmetlerimiz' : 'Services'}
                    <span class="material-symbols-outlined text-[18px] text-text-40 group-hover:rotate-180 transition-transform duration-300">keyboard_arrow_down</span>
                </button>
                
                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60]">
                    <div class="absolute -top-4 left-0 w-full h-4"></div>
                    <div class="bg-bg shadow-[0_16px_50px_rgba(0,0,0,0.15)] border border-border rounded-2xl w-[850px] flex overflow-hidden backdrop-blur-3xl">
                        
                        <!-- Left Side: Service Links -->
                        <div class="flex-[3] p-8 bg-bg/95 grid grid-cols-2 gap-8">
                            <!-- Col 1 -->
                            <div>
                                <h4 class="text-[11px] font-bold tracking-widest text-lime uppercase mb-5 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[16px]">domain</span> {lang === 'tr' ? 'Endüstri Çözümleri' : 'Industry Solutions'}
                                </h4>
                                <ul class="space-y-3.5">
                                    <li><a href={getLocalePath('/hizmetler/e-donusum', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'Sovereign e-Dönüşüm' : 'Sovereign e-Transformation'}</a></li>
                                    <li><a href={getLocalePath('/hizmetler/finansal-teknolojiler', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'Global Tahsilat Altyapısı' : 'Global Collection Infra'}</a></li>
                                    <li><a href={getLocalePath('/hizmetler/e-ticaret', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'Sınır Tanımaz Ticaret' : 'Cross-Border Commerce'}</a></li>
                                    <li><a href={getLocalePath('/hizmetler/treasury', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'Nakit ve Treasury' : 'Cash & Treasury'}</a></li>
                                </ul>
                            </div>

                            <!-- Col 2 -->
                            <div>
                                <h4 class="text-[11px] font-bold tracking-widest text-lime uppercase mb-5 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[16px]">school</span> {lang === 'tr' ? 'Platform & Destek' : 'Platform & Support'}
                                </h4>
                                <ul class="space-y-3.5">
                                    <li><a href={getLocalePath('/iletisim', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'API Dokümantasyonu' : 'API Documentation'}</a></li>
                                    <li><a href={getLocalePath('/iletisim', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'Sistem Entegrasyonu' : 'System Integration'}</a></li>
                                </ul>
                            </div>
                        </div>
                        
                        <!-- Right Side: Promo Action Card -->
                        <div class="flex-[1.2] bg-bg2 p-8 relative flex flex-col overflow-hidden border-l border-border">
                            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-lime/10 rounded-full blur-[40px]"></div>
                            <div class="relative z-10 text-left h-full flex flex-col">
                                <span class="material-symbols-outlined text-lime text-3xl mb-4">architecture</span>
                                <h4 class="font-bold text-lg mb-2 text-text-main">{lang === 'tr' ? 'Mükemmel Mimari' : 'Flawless Architecture'}</h4>
                                <p class="text-[13px] text-text-70 leading-relaxed font-light flex-grow">
                                    {lang === 'tr' ? 'Tüm finansal yapınızı uçtan uca tek sistem üzerinde sıfır manuel iş prensibiyle tasarlıyoruz.' : 'We design your entire financial structure end-to-end on a single system with zero manual work.'}
                                </p>
                                <a href={getLocalePath('/hizmetler', lang)} class="inline-flex items-center gap-1.5 text-xs font-bold text-lime hover:text-white transition-colors">
                                    {lang === 'tr' ? 'Tüm Hizmetleri Gör' : 'View All Services'} <span class="material-symbols-outlined text-sm">arrow_forward</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Kurumsal Dropdown -->
            <div class="relative group h-full flex items-center">
                <button class={`flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200 cursor-default ${(isActivePath('/hakkimizda') || isActivePath('/sektorler') || isActivePath('/insight')) ? 'text-lime font-semibold' : 'text-text-70 group-hover:text-text-main'}`}>
                    {lang === 'tr' ? 'Kurumsal' : 'Corporate'}
                    <span class="material-symbols-outlined text-[18px] text-text-40 group-hover:rotate-180 transition-transform duration-300">keyboard_arrow_down</span>
                </button>
                
                <div class="absolute top-full -translate-x-2/3 pt-4 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60]">
                    <div class="absolute -top-4 left-0 w-full h-4"></div>
                    <div class="bg-bg/95 shadow-[0_16px_50px_rgba(0,0,0,0.15)] border border-border rounded-2xl w-[500px] flex overflow-hidden backdrop-blur-3xl p-8 grid grid-cols-2 gap-8">
                        <div>
                            <h4 class="text-[11px] font-bold tracking-widest text-text-40 uppercase mb-5 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[16px]">corporate_fare</span> {lang === 'tr' ? 'Hakkımızda' : 'About Us'}
                            </h4>
                            <ul class="space-y-3.5">
                                <li><a href={getLocalePath('/hakkimizda', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-semibold">{lang === 'tr' ? 'Biz Kimiz?' : 'Who We Are'}</a></li>
                                <li><a href={getLocalePath('/sektorler', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'Hizmet Verdiğimiz Sektörler' : 'Industries We Serve'}</a></li>
                                <li><a href={getLocalePath('/iletisim', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">{lang === 'tr' ? 'İletişim & Konum' : 'Contact & Location'}</a></li>
                            </ul>
                        </div>
                        <div>
                            <h4 class="text-[11px] font-bold tracking-widest text-text-40 uppercase mb-5 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[16px]">library_books</span> {lang === 'tr' ? 'İçerik & Yasal' : 'Insights & Legal'}
                            </h4>
                            <ul class="space-y-3.5">
                                <li><a href={getLocalePath('/insight', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium">eny Insight</a></li>
                                <li><a href={getLocalePath('/kvkk', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium text-text-70">KVKK / Aydınlatma</a></li>
                                <li><a href={getLocalePath('/gizlilik-politikasi', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium text-text-70">{lang === 'tr' ? 'Gizlilik Politikası' : 'Privacy Policy'}</a></li>
                                <li><a href={getLocalePath('/cerez-politikasi', lang)} class="text-[14px] text-text-main hover:text-lime transition-colors font-medium text-text-70">{lang === 'tr' ? 'Çerez Politikası' : 'Cookie Policy'}</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Right Actions -->
        <div class="flex items-center gap-2 md:gap-4">
            <!-- Theme Toggle -->
             <div class="hidden md:flex h-full items-center">
                 <ThemeToggle />
             </div>
             
            <!-- Lang Dropdown (Desktop) -->
            <div class="relative group hidden lg:flex h-full items-center">
                <button class="flex items-center gap-1.5 px-2 py-2 rounded-lg text-sm font-medium text-text-70 group-hover:text-text-main hover:bg-bg2 transition-colors duration-200">
                    <span class="material-symbols-outlined text-[18px]">language</span>
                    {lang === 'tr' ? 'TR' : 'EN'}
                    <span class="material-symbols-outlined text-[18px] text-text-40 group-hover:rotate-180 transition-transform duration-300">keyboard_arrow_down</span>
                </button>
                <div class="absolute top-full right-0 pt-4 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60]">
                    <div class="absolute -top-4 right-0 w-full h-4"></div>
                    <div class="bg-bg/95 shadow-[0_16px_50px_rgba(0,0,0,0.15)] border border-border rounded-xl w-[140px] flex py-2 flex-col overflow-hidden backdrop-blur-3xl">
                        <a href={`https://eny.com.tr${getAlternateLangPath(currentPath, 'en')}`} class={`px-4 py-2.5 text-sm font-medium transition-colors flex items-center justify-between ${lang === 'tr' ? 'text-lime bg-lime/10 font-bold' : 'text-text-70 hover:bg-bg2 hover:text-text-main'}`} data-lang-switcher="tr">
                            Türkçe 
                            {lang === 'tr' && <span class="material-symbols-outlined text-[16px]">check</span>}
                        </a>
                        <a href={`https://e-any.com${getAlternateLangPath(currentPath, 'tr')}`} class={`px-4 py-2.5 text-sm font-medium transition-colors flex items-center justify-between ${lang === 'en' ? 'text-lime bg-lime/10 font-bold' : 'text-text-70 hover:bg-bg2 hover:text-text-main'}`} data-lang-switcher="en">
                            English
                            {lang === 'en' && <span class="material-symbols-outlined text-[16px]">check</span>}
                        </a>
                    </div>
                </div>
            </div>
            <!-- CTA (Desktop) -->
            <a href={getLocalePath('/iletisim', lang)} class="hidden sm:inline-block bg-lime text-black px-5 py-2.5 rounded-lg font-bold text-xs uppercase tracking-widest hover:bg-white hover:shadow-[0_0_20px_rgba(208,253,23,0.3)] transition-all">
                {lang === 'tr' ? 'Projenizi Konuşalım' : 'Let\'s Talk Project'}
            </a>
            
            <!-- Hamburger Button (Mobile) -->
            <button id="mobile-menu-btn" class="md:hidden flex flex-col items-center justify-center w-10 h-10 text-text-main hover:bg-bg2 rounded-lg transition-colors focus:outline-none" aria-label="Menu Toggle">
                <span class="material-symbols-outlined text-[28px]" id="menu-icon">menu</span>
            </button>
        </div>
    </div>
    
    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="absolute top-full left-0 w-full bg-bg/95 backdrop-blur-xl border-t border-border-main shadow-2xl transition-all duration-300 ease-in-out opacity-0 -translate-y-4 pointer-events-none md:hidden flex flex-col px-8 py-6 gap-2 h-[calc(100vh-70px)] overflow-y-auto z-10">
        {navItems.map((item) => (
             <a
               class={`flex items-center px-4 py-3.5 rounded-xl text-lg font-medium transition-all duration-200 ${
                 isActivePath(item.path)
                   ? 'text-lime bg-lime/10 font-bold border-l-4 border-lime'
                   : 'text-text-main hover:text-lime hover:bg-bg2'
               }`}
               href={getLocalePath(item.path, lang)}
             >
               {lang === 'tr' ? item.label : item.enLabel}
             </a>
        ))}
        
        <div class="mt-4 mb-2 h-px w-full bg-border-main"></div>

        <!-- CTA (Mobile) -->
        <a href={getLocalePath('/iletisim', lang)} class="w-full text-center bg-lime text-black px-6 py-4 rounded-xl font-bold text-sm uppercase tracking-widest hover:bg-white transition-all shadow-lg flex items-center justify-center gap-2">
            {lang === 'tr' ? 'Projenizi Konuşalım' : 'Let\'s Talk Project'}
            <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        
        <!-- Theme Toggle (Mobile) -->
        <div class="mt-2 flex items-center justify-center">
            <ThemeToggle />
        </div>

        <!-- Lang Toggle (Mobile) -->
        <div class="mt-4 flex items-center justify-center bg-bg2 rounded-full p-1.5 gap-1 w-full max-w-[240px] mx-auto border border-border-main">
             {lang === 'tr' ? (
                 <>
                     <span class="px-6 py-2.5 rounded-full bg-lime text-black text-sm font-bold tracking-wide w-1/2 text-center">TR</span>
                     <a href={`https://e-any.com${alternateLangPath}`} class="px-6 py-2.5 rounded-full text-text-40 text-sm font-bold tracking-wide hover:text-text-main transition-colors w-1/2 text-center" data-lang-switcher="en">EN</a>
                 </>
             ) : (
                 <>
                     <a href={`https://eny.com.tr${alternateLangPath}`} class="px-6 py-2.5 rounded-full text-text-40 text-sm font-bold tracking-wide hover:text-text-main transition-colors w-1/2 text-center" data-lang-switcher="tr">TR</a>
                     <span class="px-6 py-2.5 rounded-full bg-lime text-black text-sm font-bold tracking-wide w-1/2 text-center">EN</span>
                 </>
             )}
        </div>
    </div>
</nav>

<script>
  // Scroll visibility effect
  const nav = document.getElementById('main-nav');
  const isHome = nav ? nav.getAttribute('data-is-home') === 'true' : true;

  window.addEventListener('scroll', () => {
    if (nav) {
      if (window.scrollY > 80) {
        nav.classList.add('scrolled');
      } else {
        if (isHome) {
          nav.classList.remove('scrolled');
        }
      }
    }
  });

  // Mobile Menu Toggle
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  
  if (mobileBtn && mobileMenu && menuIcon) {
    mobileBtn.addEventListener('click', () => {
      const isExpanded = mobileMenu.classList.contains('opacity-100');
      if (isExpanded) {
        mobileMenu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        mobileMenu.classList.add('opacity-0', '-translate-y-4', 'pointer-events-none');
        menuIcon.textContent = 'menu';
        document.body.style.overflow = '';
      } else {
        mobileMenu.classList.remove('opacity-0', '-translate-y-4', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        menuIcon.textContent = 'close';
        document.body.style.overflow = 'hidden';
      }
    });
  }

  // Language Preference Persistence
  document.querySelectorAll('[data-lang-switcher]').forEach(el => {
    el.addEventListener('click', (e) => {
      const newLang = el.getAttribute('data-lang-switcher');
      if (newLang) {
        localStorage.setItem('eny-lang-pref', newLang);
      }
    });
  });
</script>
